# Background CPU decreased: physical node CPU drops from 800 to 600.
# Only s1 sends a new message; s2's store load is unchanged.
#
# Without the fix, this would have no effect on nodes-cpu-load
# because store loads are unchanged (sum stays 500).
make-store-load-msg store-id=1 node-id=1 num-stores=2 cpu-per-second=200 stores-cpu-rate=500 node-cpu-usage=600 node-cpu-capacity=2000
