# MVCC timestamp is above startTS but the commit timestamp is at or below
# startTS. The record should not be emitted because we filter on the actual
# commit timestamp embedded in the transaction proto, not the MVCC timestamp.
put-txn-record anchor=b mvcc-ts=10 commit-ts=4 status=COMMITTED id=txn1 lock-spans=b-c
----

catchup-scan start-ts=5
----
<no events>

# MVCC timestamp well above startTS, commit timestamp exactly at startTS —
# still excluded (startTS is exclusive).
put-txn-record anchor=c mvcc-ts=20 commit-ts=5 status=COMMITTED id=txn2 lock-spans=c-d
----

catchup-scan start-ts=5
----
<no events>

# MVCC timestamp above startTS and commit timestamp also above startTS — emitted.
put-txn-record anchor=d mvcc-ts=20 commit-ts=6 status=COMMITTED id=txn3 lock-spans=d-e
----

catchup-scan start-ts=5
----
committed anchor=d commit-ts=6 write-spans=[d-e]
