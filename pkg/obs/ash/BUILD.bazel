    srcs = [
        "buffer_test.go",
        "sampler_test.go",
        "work_state_test.go",
    ],
    embed = [":ash"],
    deps = [
        "//pkg/roachpb",
        "//pkg/settings/cluster",
        "//pkg/testutils",
        "//pkg/util/stop",
        "@com_github_cockroachdb_errors//:errors",
        "@com_github_petermattis_goid//:goid",
        "@com_github_stretchr_testify//require",
    ],
