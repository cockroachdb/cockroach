# NB: We override the default target_util (0.80) to 0.95 so that
# canBurstTarget = 0.95 + 0.05 = 1.0. The per-group burst bucket refill
# scales by 1/canBurstTarget, so this makes its expected values land on
# round numbers (5000 tokens/s * BurstFrac(0.20) = 1000) and keeps them
# stable while burst-bucket plumbing is in flux. If the defaults change
# again, only this override needs updating.
setClusterSettings target=0.95 burst=0.05
----
SET CLUSTER SETTING admission.cpu_time_tokens.target_util = 0.95
SET CLUSTER SETTING admission.cpu_time_tokens.target_util.burst_delta = 0.05
cpuTTG can_burst=0 no_burst=0
burstM  0

# The first call to resetInterval should add refillRates to all
# buckets. We want the buckets to start full, and cpuTimeTokenFiller calls
# resetInterval on startup. The refill rates are below for reference:
#
#   can_burst no_burst
#   5000      4000
#
# The target CPU utilizations are passed as an argument to fit, and they
# are a function of cluster settings, plus some simple logic in resetInterval.
resetInterval
----
fit(
	no_burst -> 95%
	can_burst -> 100%
)
cpuTTG can_burst=5000 no_burst=4000
burstM  1000

# set-tokens v=0 simulates tokens being taken due to admitted work.
set-tokens v=0
----
cpuTTG can_burst=0 no_burst=0
burstM  0

# Over an interval (between calls to resetInterval), the refill rate should
# be added to each bucket. Again, here are the refill rates:
#
#   can_burst no_burst
#   5000      4000
#
# The rates should be added as smoothly as possible over the 5 tick (
# interval (see allocate remaining=5 calls below). So each call to
# allocate should add refill rate / 5 tokens. So the amount that each call
# to allocate should add is below:
#
#   can_burst no_burst
#   1000      800
#
# Burst bucket state is also printed. See cpu_time_token_burst.go for
# context on the idea of burst buckets in general.
allocate remaining=5
----
cpuTTG can_burst=1000 no_burst=800
burstM  200

allocate remaining=4
----
cpuTTG can_burst=2000 no_burst=1600
burstM  400

allocate remaining=3
----
cpuTTG can_burst=3000 no_burst=2400
burstM  600

allocate remaining=2
----
cpuTTG can_burst=4000 no_burst=3200
burstM  800

allocate remaining=1
----
cpuTTG can_burst=5000 no_burst=4000
burstM  1000

resetInterval
----
fit(
	no_burst -> 95%
	can_burst -> 100%
)
cpuTTG can_burst=5000 no_burst=4000
burstM  1000

# resetInterval has been called, so a new interval has started.
# So in theory more tokens can be added. But in this case the
# buckets are already full. The max capacity for each bucket is
# one second worth of tokens at the current refill rate. So no
# tokens will be added on this call to allocate.
allocate remaining=5
----
cpuTTG can_burst=5000 no_burst=4000
burstM  1000

set-tokens v=0
----
cpuTTG can_burst=0 no_burst=0
burstM  0

# In the interval, one call to allocateTokens was made already.
# So we do not expect the full rates to end up in the buckets.
# We expect the full rates - one tick worth of tokens to end up
# in the bucket instead.
#
#   can_burst    no_burst
#   5000-1000    4000-800
#
# Which yields:
#
#   can_burst no_burst
#   4000      3200
#
# Note that all remaining tokens were added in a single call to
# allocate, which simulates three ticks being dropped (allocate
# remaining=4, allocate remaining=3, & allocate remaining=2). See
# the comment about dropped ticks above cpuTimeTokenFiller for more.
allocate remaining=1
----
cpuTTG can_burst=4000 no_burst=3200
burstM  800

resetInterval
----
fit(
	no_burst -> 95%
	can_burst -> 100%
)
cpuTTG can_burst=4000 no_burst=3200
burstM  800

set-tokens v=0
----
cpuTTG can_burst=0 no_burst=0
burstM  0

# In this interval, no call to allocateTokens so far, so we do
# expect the full rates to end up in the bucket, again in a single
# call to allocate.
allocate remaining=1
----
cpuTTG can_burst=5000 no_burst=4000
burstM  1000

resetInterval
----
fit(
	no_burst -> 95%
	can_burst -> 100%
)
cpuTTG can_burst=5000 no_burst=4000
burstM  1000

set-tokens v=0
----
cpuTTG can_burst=0 no_burst=0
burstM  0

# In this interval, two ticks, so half of the tokens should be added
# on the first call to allocate, and the other half on the second call.
allocate remaining=2
----
cpuTTG can_burst=2500 no_burst=2000
burstM  500

allocate remaining=1
----
cpuTTG can_burst=5000 no_burst=4000
burstM  1000

# These final cases test how cpuTimeTokenAllocator handles changes to
# refillRates. See the comment above deltaRefillRates for a full explanation
# of the approach. TLDR is the allocator will compute the amount of change in
# refillRates & add it immediately to the buckets, before any calls to allocate
# are made. Thus, if we increase refillRates by one (on all buckets), we expect
# one token is added to all buckets, as below.
resetInterval increase_rates_by=1
----
fit(
	no_burst -> 95%
	can_burst -> 100%
)
cpuTTG can_burst=5001 no_burst=4001
burstM  1000

set-tokens v=0
----
cpuTTG can_burst=0 no_burst=0
burstM  0

# The updated refillRate is added to the buckets (in one tick for simplicity,
# since remaining=1).
allocate remaining=1
----
cpuTTG can_burst=5001 no_burst=4001
burstM  1000

# Another test of a change to refillRates. If we decrease refillRates by two
# (on all buckets), we expect two tokens to be removed from all buckets, as
# below.
resetInterval increase_rates_by=-2
----
fit(
	no_burst -> 95%
	can_burst -> 100%
)
cpuTTG can_burst=4999 no_burst=3999
burstM  999

set-tokens v=0
----
cpuTTG can_burst=0 no_burst=0
burstM  0

# The updated refillRate is added to the buckets (in one tick for simplicity,
# since remaining=1).
allocate remaining=1
----
cpuTTG can_burst=4999 no_burst=3999
burstM  999

set-tokens v=0
----
cpuTTG can_burst=0 no_burst=0
burstM  0

# Test of computation of target CPU utilizations from overridden cluster
# settings. The no_burst targets are configurable by cluster settings, which
# are overridden in this test case. A can_burst target adds
# admission.cpu_time_tokens.target_util.burst_delta, which is also overridden
# here, to the corresponding no_burst target. See resetInterval for more.
setClusterSettings burst=0.1
----
SET CLUSTER SETTING admission.cpu_time_tokens.target_util.burst_delta = 0.1
cpuTTG can_burst=0 no_burst=0
burstM  0

resetInterval
----
fit(
	no_burst -> 95%
	can_burst -> 105%
)
cpuTTG can_burst=0 no_burst=0
burstM  0

# Test that both allocateTokens and resetInterval clamp bucket token counts to
# their per-bucket minimums. The granter minimums are computed from the current
# refill rates {4999, 3999}:
#   can_burst: 0              (top priority, floor is 0)
#   no_burst:  3999 - 4999 = -1000
#
# The burst bucket also has a minimum. See cpu_time_token_burst.go for the
# capacity and minimum formulas.

# Test allocateTokens path. Drive buckets deeply negative, then allocate. The
# added tokens (the full refill rates) are far too small to overcome the deficit,
# so each bucket clamps to its minimum.
set-tokens v=-10000000
----
cpuTTG can_burst=-10000000 no_burst=-10000000
burstM  -10000000

allocate remaining=1
----
cpuTTG can_burst=0 no_burst=-1000
burstM  -238

# Test resetInterval path. Drive buckets deeply negative again. resetInterval
# has delta=0 (rates unchanged), but the floor still clamps.
set-tokens v=-10000000
----
cpuTTG can_burst=-10000000 no_burst=-10000000
burstM  -10000000

resetInterval
----
fit(
	no_burst -> 95%
	can_burst -> 105%
)
cpuTTG can_burst=0 no_burst=-1000
burstM  -238

# ----- Dampening tests -----
#
# Restore the baseline overrides (the earlier setClusterSettings test set
# burst=0.1). The prior tests left model.rates at 4999/3999 (after
# increase_rates_by=+1 then -2); resetInterval increase_rates_by=1 below
# restores 5000/4000.
setClusterSettings target=0.95 burst=0.05
----
SET CLUSTER SETTING admission.cpu_time_tokens.target_util = 0.95
SET CLUSTER SETTING admission.cpu_time_tokens.target_util.burst_delta = 0.05
cpuTTG can_burst=0 no_burst=-1000
burstM  -238

resetInterval increase_rates_by=1
----
fit(
	no_burst -> 95%
	can_burst -> 100%
)
cpuTTG can_burst=1 no_burst=-999
burstM  -238

# Default threshold=32, procs=10:
#   runnable >= 320       -> descend
#   runnable in [240,320) -> hold
#   runnable in [40,240)  -> recover
#   runnable < 40         -> snap to 1.0
set-cpu-load runnable=320 procs=10
----
cpu-load: runnable=320 procs=10

set-tokens v=0
----
cpuTTG can_burst=0 no_burst=0
burstM  0

# Descend: factor 1.0 -> 0.99. Granter scaled by 0.99; per-group burst
# bucket is not scaled.
allocate remaining=1
----
cpuTTG can_burst=4950 no_burst=3960
burstM  1000

# Descend again: 0.99 -> 0.98.
resetInterval
----
fit(
	no_burst -> 95%
	can_burst -> 100%
)
cpuTTG can_burst=4950 no_burst=3960
burstM  1000

set-tokens v=0
----
cpuTTG can_burst=0 no_burst=0
burstM  0

allocate remaining=1
----
cpuTTG can_burst=4900 no_burst=3920
burstM  1000

# Hold: runnable=260 is in [240, 320), so the factor stays at 0.98.
set-cpu-load runnable=260 procs=10
----
cpu-load: runnable=260 procs=10

resetInterval
----
fit(
	no_burst -> 95%
	can_burst -> 100%
)
cpuTTG can_burst=4900 no_burst=3920
burstM  1000

set-tokens v=0
----
cpuTTG can_burst=0 no_burst=0
burstM  0

allocate remaining=1
----
cpuTTG can_burst=4900 no_burst=3920
burstM  1000

# Snap-back: runnable=20 is below 40, so the factor jumps 0.98 -> 1.0
# in a single tick, bypassing the per-tick recovery ramp.
set-cpu-load runnable=20 procs=10
----
cpu-load: runnable=20 procs=10

resetInterval
----
fit(
	no_burst -> 95%
	can_burst -> 100%
)
cpuTTG can_burst=4900 no_burst=3920
burstM  1000

set-tokens v=0
----
cpuTTG can_burst=0 no_burst=0
burstM  0

allocate remaining=1
----
cpuTTG can_burst=5000 no_burst=4000
burstM  1000
