# Simple tryGet calls.
init no_burst=1
----
cpuTTG can_burst=0 no_burst=1
requester: waitingRequests: false, returnValueFromHasWaitingRequests: no_burst, returnValueFromGranted: 0

try-get v=1
----
kv: tryGet(1) returned true
cpuTTG can_burst=-1 no_burst=0

try-get v=1
----
kv: tryGet(1) returned false

# Returns tokens used since last call to reset-tokens-used.
# Since only one try-get v=1 succeeded, only one token used.
reset-tokens-used
----
reset-tokens-used-in-interval() returned 1

# Since reset-tokens-used just called, should return zero.
reset-tokens-used
----
reset-tokens-used-in-interval() returned 0

# More simple tryGet calls.
init no_burst=2
----
cpuTTG can_burst=0 no_burst=2
requester: waitingRequests: false, returnValueFromHasWaitingRequests: no_burst, returnValueFromGranted: 0

# For cpuTimeTokenGranter, this is a NOP. Still, it will be
# called in production. So best to test it doesn't panic, or similar.
continue-grant-chain
----
kv: continueGrantChain

try-get v=1
----
kv: tryGet(1) returned true
cpuTTG can_burst=-1 no_burst=1

try-get v=1
----
kv: tryGet(1) returned true
cpuTTG can_burst=-2 no_burst=0

try-get v=1
----
kv: tryGet(1) returned false

# Since two try-gets v=1 succeeded, should return two.
reset-tokens-used
----
reset-tokens-used-in-interval() returned 2

# returnGrant adds tokens to the buckets, when a positive count is used.
init no_burst=1
----
cpuTTG can_burst=0 no_burst=1
requester: waitingRequests: false, returnValueFromHasWaitingRequests: no_burst, returnValueFromGranted: 0

return-grant v=1
----
kv: returnGrant(1)
cpuTTG can_burst=1 no_burst=2

try-get v=1
----
kv: tryGet(1) returned true
cpuTTG can_burst=0 no_burst=1

try-get v=1
----
kv: tryGet(1) returned true
cpuTTG can_burst=-1 no_burst=0

# The net of one return-grant v=1 with two try-gets v=1 is one
# token used.
reset-tokens-used
----
reset-tokens-used-in-interval() returned 1

# Simple tookWithoutPermission test.
init no_burst=3
----
cpuTTG can_burst=0 no_burst=3
requester: waitingRequests: false, returnValueFromHasWaitingRequests: no_burst, returnValueFromGranted: 0

took-without-permission v=3
----
kv: tookWithoutPermission(3)
cpuTTG can_burst=-3 no_burst=0

try-get v=1
----
kv: tryGet(1) returned false

# took-without-permission v=3 is the only successful call, so three tokens used.
reset-tokens-used
----
reset-tokens-used-in-interval() returned 3

# Test granting. A request will be admitted.
init waiter=2
----
cpuTTG can_burst=0 no_burst=0
requester: waitingRequests: true, returnValueFromHasWaitingRequests: no_burst, returnValueFromGranted: 2

return-grant v=2
----
kv: returnGrant(2)
kv: granted in chain 0, and returning 2

# The net of one return-grant v=2 with that grant leading to admission of request
# with token count equal to two is zero tokens used.
reset-tokens-used
----
reset-tokens-used-in-interval() returned 0

# Test granting. Two requests will be admitted.
init can_burst=-1 no_burst=-1 waiter=1
----
cpuTTG can_burst=-1 no_burst=-1
requester: waitingRequests: true, returnValueFromHasWaitingRequests: no_burst, returnValueFromGranted: 1

# With three returned, no_burst will have two tokens. Thus two
# requests can be granted admission. Note that the test requester is not
# stateful. In init, waiter=1 means the requester always has a waiting
# request, and the ret value from granted is always 1. Thus, after two
# requests are granted admission, the bucket is empty again.
return-grant v=3
----
kv: returnGrant(3)
kv: granted in chain 0, and returning 1
kv: granted in chain 0, and returning 1
cpuTTG can_burst=0 no_burst=0

# The net of one return-grant v=3 with that grant leading to admission of two requests
# with token count equal to one is -1 tokens used.
reset-tokens-used
----
reset-tokens-used-in-interval() returned -1

# Simple tryGet calls, with burst this time.
init can_burst=1
----
cpuTTG can_burst=1 no_burst=0
requester: waitingRequests: false, returnValueFromHasWaitingRequests: no_burst, returnValueFromGranted: 0

try-get v=1
----
kv: tryGet(1) returned false

try-get burst v=1
----
kv: tryGet(1) returned true
cpuTTG can_burst=0 no_burst=-1

try-get burst v=1
----
kv: tryGet(1) returned false

# Since one try-get v=1 succeeded, should return one.
reset-tokens-used
----
reset-tokens-used-in-interval() returned 1

# Test granting, with burst. After the call to return-grant, can_burst will
# have enough tokens to grant. So grant a burst request.
init can_burst=0 no_burst=-1 waiter=1 burst_waiter
----
requester: waitingRequests: true, returnValueFromHasWaitingRequests: can_burst, returnValueFromGranted: 1

return-grant v=1
----
kv: returnGrant(1)
kv: granted in chain 0, and returning 1

# The net of one return-grant v=1 with that grant leading to admission of one request
# with token count equal to one is zero tokens used.
reset-tokens-used
----
reset-tokens-used-in-interval() returned 0

# Test granting, with burst. After the call to return-grant, only no_burst will
# have enough tokens to grant. So no grant, since the waiting request is a burst request.
init can_burst=-1 no_burst=0 waiter=1 burst_waiter
----
cpuTTG can_burst=-1 no_burst=0
requester: waitingRequests: true, returnValueFromHasWaitingRequests: can_burst, returnValueFromGranted: 1

return-grant v=1
----
kv: returnGrant(1)
cpuTTG can_burst=0 no_burst=1

# The net of one return-grant v=1 with that grant not leading to any admission is
# -1 tokens used.
reset-tokens-used
----
reset-tokens-used-in-interval() returned -1

# Test refill, which is the interface cpuTimeTokenFiller uses to add tokens to
# the buckets. Note that there is a single non-burstable request waiting
# for admission.
init waiter=1
----
cpuTTG can_burst=0 no_burst=0
requester: waitingRequests: true, returnValueFromHasWaitingRequests: no_burst, returnValueFromGranted: 1

# The arguments to refill are hard-coded in the test code, but they are also
# shown in the below output. The corresponding entry in delta is added to every
# bucket, subject to a max capacity of the corresponding entry in cap and a min
# floor of the corresponding entry in min. Note as per the call init above,
# the test requester always reports a waiting noBurst request that returns 1
# token. So after adding can_burst=5, no_burst=4, the granter grants 4 times
# (until no_burst hits 0), deducting 1 from each bucket per grant. Final state:
# can_burst=5-4=1, no_burst=4-4=0.
refill
----
kv: granted in chain 0, and returning 1
kv: granted in chain 0, and returning 1
kv: granted in chain 0, and returning 1
kv: granted in chain 0, and returning 1
refill(
	can_burst -> delta: 5, cap: 20, min: 0
	no_burst -> delta: 4, cap: 16, min: -4
)
cpuTTG can_burst=1 no_burst=0

# Refilling the buckets does not count as token usage. The only usage that happens
# here is that four requests with token count equal to one are granted admission,
# due to the refill (see "granted in..." messages above). So four tokens used.
reset-tokens-used
----
reset-tokens-used-in-interval() returned 4

# Test that refill enforces both ceiling and floor. can_burst starts at 16,
# so 16 + delta(5) = 21 > cap(20), demonstrating the ceiling. The no_burst
# bucket starts deeply negative, so it is clamped to its floor of -4.
init no_burst=-100 can_burst=16
----
cpuTTG can_burst=16 no_burst=-100
requester: waitingRequests: false, returnValueFromHasWaitingRequests: no_burst, returnValueFromGranted: 0

refill
----
refill(
	can_burst -> delta: 5, cap: 20, min: 0
	no_burst -> delta: 4, cap: 16, min: -4
)
cpuTTG can_burst=20 no_burst=-4
