stage-query phase=PostCommitPhase stage=1:16
SELECT c2.relname AS index_name
  FROM pg_catalog.pg_index i
  JOIN pg_catalog.pg_class c ON c.oid = i.indrelid
  JOIN pg_catalog.pg_class c2 ON c2.oid = i.indexrelid
  WHERE c.relname = 'table_regional_by_row' AND i.indisready AND i.indisvalid
  ORDER BY c2.relname;
