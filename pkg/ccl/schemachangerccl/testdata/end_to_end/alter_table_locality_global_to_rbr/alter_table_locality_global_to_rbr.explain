/* setup */
CREATE DATABASE multiregion_db PRIMARY REGION "us-east1" REGIONS "us-east2", "us-east3";
CREATE TABLE multiregion_db.public.t (
  pk INT PRIMARY KEY,
  i INT NOT NULL,
  j INT NOT NULL UNIQUE,
  INDEX idx(i)
) LOCALITY GLOBAL;

/* test */
EXPLAIN (DDL) ALTER TABLE multiregion_db.public.t SET LOCALITY REGIONAL BY ROW;
