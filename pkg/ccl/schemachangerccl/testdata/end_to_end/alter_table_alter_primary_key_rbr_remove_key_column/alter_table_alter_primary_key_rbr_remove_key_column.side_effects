/* setup */
CREATE DATABASE multiregion_db PRIMARY REGION "us-east1" REGIONS "us-east2", "us-east3" SURVIVE REGION FAILURE;
CREATE TABLE multiregion_db.public.table_regional_by_row (
  k1 INT NOT NULL,
  k2 INT NOT NULL,
  primary key (k1, k2),
  V STRING,
  index idx_v(v)
) LOCALITY REGIONAL BY ROW;
