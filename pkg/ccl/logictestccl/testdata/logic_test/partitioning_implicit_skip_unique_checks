# LogicTest: local local-legacy-schema-changer

# Test the skip_unique_checks storage parameter on UNIQUE indexes in PARTITION
# ALL BY tables. When a table uses PARTITION ALL BY, unique indexes have the
# partition column implicitly added, which creates UNIQUE WITHOUT INDEX
# constraints since global uniqueness can't be guaranteed by the partitioned
# index.

statement ok
SET experimental_enable_implicit_column_partitioning = true

# checked_index: extracts the index name from an EXPLAIN info line containing
# "table:". Used to check which indexes have unique checks planned.
statement ok
CREATE FUNCTION checked_index(info STRING) RETURNS STRING LANGUAGE SQL AS $$
  SELECT regexp_extract(info, 'table:\s+\w+@([\w_]+)')
$$

# show_index: extracts the definition of a named index from a SHOW CREATE
# statement.
statement ok
CREATE FUNCTION show_index(stmt STRING, idx STRING) RETURNS STRING LANGUAGE SQL AS $$
  SELECT regexp_extract(stmt, '(' || idx || '[^\n]*)')
$$

statement ok
CREATE TABLE t (
  region STRING NOT NULL,
  a INT PRIMARY KEY,
  b INT,
  UNIQUE INDEX idx_b (b),
  CHECK (region IN ('us-west', 'us-east', 'eu-west'))
) PARTITION ALL BY LIST (region) (
  PARTITION us_west VALUES IN (('us-west')),
  PARTITION us_east VALUES IN (('us-east')),
  PARTITION eu_west VALUES IN (('eu-west'))
)

# Without the storage parameter, unique checks are planned for the implicitly
# partitioned unique index and primary key.
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN INSERT INTO t VALUES ('us-west', 1, 10), ('us-east', 2, 20)]
WHERE info ~ 'table:';
----
t_pkey
idx_b

# Set the storage parameter to skip unique checks on the secondary index.
statement ok
ALTER INDEX t@idx_b SET (skip_unique_checks = true)

query T
SELECT show_index(create_statement, 'idx_b') FROM [SHOW CREATE TABLE t]
----
idx_b (b ASC) WITH (skip_unique_checks=true),

# Now unique checks should not be planned for the secondary.
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN INSERT INTO t VALUES ('us-west', 3, 30), ('us-east', 4, 40)]
WHERE info ~ 'table:';
----
t_pkey

# Set the storage parameter to skip unique checks on the primary index.
statement ok
ALTER INDEX t@t_pkey SET (skip_unique_checks = true)

query T
SELECT show_index(create_statement, 't_pkey') FROM [SHOW CREATE TABLE t]
----
t_pkey PRIMARY KEY (a ASC) WITH (skip_unique_checks=true),

# Now unique checks should not be planned for the primary either.
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN INSERT INTO t VALUES ('us-west', 5, 50), ('us-east', 6, 60)]
WHERE info ~ 'table:';
----

# Reset the parameter for the secondary.
statement ok
ALTER INDEX t@idx_b RESET (skip_unique_checks)

query T
SELECT show_index(create_statement, 'idx_b') FROM [SHOW CREATE TABLE t]
----
idx_b (b ASC),

# Checks should be planned again for the secondary only.
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN INSERT INTO t VALUES ('us-west', 7, 70), ('us-east', 8, 80)]
WHERE info ~ 'table:';
----
idx_b

# Reset the parameter for the primary.
statement ok
ALTER INDEX t@t_pkey RESET (skip_unique_checks)

query T
SELECT show_index(create_statement, 't_pkey') FROM [SHOW CREATE TABLE t]
----
t_pkey PRIMARY KEY (a ASC),

# Checks should be planned again for both indexes.
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN INSERT INTO t VALUES ('us-west', 9, 90), ('us-east', 10, 100)]
WHERE info ~ 'table:';
----
t_pkey
idx_b

# Test disabling via SET (skip_unique_checks = false) instead of RESET.
statement ok
ALTER INDEX t@idx_b SET (skip_unique_checks = true)

statement ok
ALTER INDEX t@idx_b SET (skip_unique_checks = false)

query T
SELECT show_index(create_statement, 'idx_b') FROM [SHOW CREATE TABLE t]
----
idx_b (b ASC),

# Checks should be planned for both indexes after disabling via SET false.
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN INSERT INTO t VALUES ('us-west', 9, 90), ('us-east', 10, 100)]
WHERE info ~ 'table:';
----
t_pkey
idx_b

# Test creating an index with skip_unique_checks set at creation time.
statement ok
ALTER TABLE t ADD COLUMN c INT

statement ok
CREATE UNIQUE INDEX idx_c ON t(c) WITH (skip_unique_checks = true)

query T
SELECT show_index(create_statement, 'idx_c') FROM [SHOW CREATE TABLE t]
----
idx_c (c ASC) WITH (skip_unique_checks=true),

# Verify that unique checks are not planned for the newly created index.
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN INSERT INTO t VALUES ('us-west', 11, 110, 1000), ('us-east', 12, 120, 2000)]
WHERE info ~ 'table:';
----
t_pkey
idx_b

# Reset the parameter for idx_c.
statement ok
ALTER INDEX t@idx_c RESET (skip_unique_checks)

query T
SELECT show_index(create_statement, 'idx_c') FROM [SHOW CREATE TABLE t]
----
idx_c (c ASC),

# Checks should now be planned for idx_c as well.
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN INSERT INTO t VALUES ('us-west', 13, 130, 3000), ('us-east', 14, 140, 4000)]
WHERE info ~ 'table:';
----
t_pkey
idx_b
idx_c

