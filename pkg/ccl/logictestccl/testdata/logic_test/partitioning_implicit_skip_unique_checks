----

# Add a new column for the new primary key.
statement ok
ALTER TABLE t ADD COLUMN d INT NOT NULL DEFAULT 0

# ALTER PRIMARY KEY without WITH clause.
# The old PK (becomes unique secondary) and recreated secondaries preserve
# skip_unique_checks, but the NEW primary key does NOT inherit it (resets to
# default false).
statement ok
ALTER TABLE t ALTER PRIMARY KEY USING COLUMNS (d)

query T
SELECT show_index(create_statement, 't_pkey') FROM [SHOW CREATE TABLE t]
----
t_pkey PRIMARY KEY (d ASC),

query T
SELECT show_index(create_statement, 't_a_key') FROM [SHOW CREATE TABLE t]
----
t_a_key (a ASC) WITH (skip_unique_checks=true),

# New PK has checks, but secondaries don't (old PK->secondary and recreated
# indexes preserved it).
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN INSERT INTO t VALUES ('us-west', 17, 170, 7000, 1), ('us-east', 18, 180, 8000, 2)]
WHERE info ~ 'table:';
----
t_pkey

# Now ALTER PRIMARY KEY again, this time WITH (skip_unique_checks = true).
statement ok
ALTER TABLE t ADD COLUMN e INT NOT NULL DEFAULT 0

statement ok
ALTER TABLE t ALTER PRIMARY KEY USING COLUMNS (e) WITH (skip_unique_checks = true)

query T
SELECT show_index(create_statement, 't_pkey') FROM [SHOW CREATE TABLE t]
----
t_pkey PRIMARY KEY (e ASC) WITH (skip_unique_checks=true),

query T
SELECT show_index(create_statement, 't_d_key') FROM [SHOW CREATE TABLE t]
----
t_d_key (d ASC),

# New PK has skip_unique_checks=true (from WITH), but old PK->unique secondary
# (t_d_key) does not, so it still needs checks.
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN INSERT INTO t VALUES ('us-west', 19, 190, 9000, 1, 1), ('us-east', 20, 200, 10000, 2, 2)]
WHERE info ~ 'table:';
----
t_d_key

# Test skip_unique_checks set at CREATE TABLE time in various inline forms.

# Column-level PRIMARY KEY WITH.
statement ok
CREATE TABLE t_pk_inline (
  region STRING NOT NULL,
  a INT PRIMARY KEY WITH (skip_unique_checks = true),
  CHECK (region IN ('us-west', 'us-east', 'eu-west'))
) PARTITION ALL BY LIST (region) (
  PARTITION us_west VALUES IN (('us-west')),
  PARTITION us_east VALUES IN (('us-east')),
  PARTITION eu_west VALUES IN (('eu-west'))
)

query T
SELECT show_index(create_statement, 't_pk_inline_pkey') FROM [SHOW CREATE TABLE t_pk_inline]
----
t_pk_inline_pkey PRIMARY KEY (a ASC) WITH (skip_unique_checks=true),

# Table-level PRIMARY KEY WITH.
statement ok
CREATE TABLE t_pk_table_level (
  region STRING NOT NULL,
  a INT,
  b INT,
  PRIMARY KEY (a, b) WITH (skip_unique_checks = true),
  CHECK (region IN ('us-west', 'us-east', 'eu-west'))
) PARTITION ALL BY LIST (region) (
  PARTITION us_west VALUES IN (('us-west')),
  PARTITION us_east VALUES IN (('us-east')),
  PARTITION eu_west VALUES IN (('eu-west'))
)

query T
SELECT show_index(create_statement, 't_pk_table_level_pkey') FROM [SHOW CREATE TABLE t_pk_table_level]
----
t_pk_table_level_pkey PRIMARY KEY (a ASC, b ASC) WITH (skip_unique_checks=true),

# Inline UNIQUE INDEX WITH in CREATE TABLE.
statement ok
CREATE TABLE t_unique_inline (
  region STRING NOT NULL,
  a INT PRIMARY KEY,
  b INT,
  c INT,
  UNIQUE INDEX idx_b (b) WITH (skip_unique_checks = true),
  UNIQUE INDEX idx_c (c),
  CHECK (region IN ('us-west', 'us-east', 'eu-west'))
) PARTITION ALL BY LIST (region) (
  PARTITION us_west VALUES IN (('us-west')),
  PARTITION us_east VALUES IN (('us-east')),
  PARTITION eu_west VALUES IN (('eu-west'))
)

query T
SELECT show_index(create_statement, 'idx_b') FROM [SHOW CREATE TABLE t_unique_inline]
----
idx_b (b ASC) WITH (skip_unique_checks=true),

query T
SELECT show_index(create_statement, 'idx_c') FROM [SHOW CREATE TABLE t_unique_inline]
----
idx_c (c ASC),

# idx_b has skip_unique_checks, so only t_pkey and idx_c should have checks.
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN INSERT INTO t_unique_inline VALUES ('us-west', 1, 10, 100), ('us-east', 2, 20, 200)]
WHERE info ~ 'table:';
----
t_unique_inline_pkey
idx_c

# Test UPDATE: unique checks should also be skipped for idx_b during updates.
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN UPDATE t_unique_inline SET b = b + 1, c = c + 1 WHERE a = 1]
WHERE info ~ 'table:' AND checked_index(info) IS NOT NULL;
----
t_unique_inline_pkey
idx_c

# Test UPSERT: unique checks should also be skipped for idx_b during upserts.
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN UPSERT INTO t_unique_inline VALUES ('us-west', 1, 10, 100), ('us-east', 2, 20, 200)]
WHERE info ~ 'table:';
----
t_unique_inline_pkey
idx_c

# Test skip_unique_checks on a partial unique index.
statement ok
CREATE TABLE t_partial (
  region STRING NOT NULL,
  a INT PRIMARY KEY,
  b INT,
  UNIQUE INDEX idx_partial (b) WHERE b > 0,
  CHECK (region IN ('us-west', 'us-east', 'eu-west'))
) PARTITION ALL BY LIST (region) (
  PARTITION us_west VALUES IN (('us-west')),
  PARTITION us_east VALUES IN (('us-east')),
  PARTITION eu_west VALUES IN (('eu-west'))
)

# Without skip_unique_checks, the partial index should have unique checks.
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN INSERT INTO t_partial VALUES ('us-west', 1, 10), ('us-east', 2, 20)]
WHERE info ~ 'table:';
----
t_partial_pkey
idx_partial

statement ok
ALTER INDEX t_partial@idx_partial SET (skip_unique_checks = true)

# Verify via SHOW CREATE that skip_unique_checks is set. The output format
# differs between the declarative and legacy schema changers for partial indexes.
query B
SELECT create_statement LIKE '%idx_partial%skip_unique_checks%' FROM [SHOW CREATE TABLE t_partial]
----
true

# With skip_unique_checks, unique checks for the partial index should be skipped.
query T
SELECT DISTINCT checked_index(info)
FROM [EXPLAIN INSERT INTO t_partial VALUES ('us-west', 3, 30), ('us-east', 4, 40)]
WHERE info ~ 'table:';
----
t_partial_pkey

# Test CREATE with skip_unique_checks on a partial index.
statement ok
CREATE UNIQUE INDEX idx_partial2 ON t_partial(b) WITH (skip_unique_checks = true) WHERE b < 0

query B
SELECT create_statement LIKE '%idx_partial2%skip_unique_checks%' FROM [SHOW CREATE TABLE t_partial]
----
true
