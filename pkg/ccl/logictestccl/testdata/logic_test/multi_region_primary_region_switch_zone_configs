                    gc.ttlseconds = 14400,
                    num_replicas = 5,
                    num_voters = 3,
                    constraints = '{+region=ap-southeast-2: 1, +region=ca-central-1: 1, +region=us-east-1: 1}',
                    voter_constraints = '[+region=us-east-1]',
                    lease_preferences = '[[+region=us-east-1]]'

