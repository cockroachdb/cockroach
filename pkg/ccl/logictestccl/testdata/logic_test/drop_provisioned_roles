# ----------------------------------------------------------------------
# Test 7: Dependency skip — user owning objects is skipped with NOTICE.
# ----------------------------------------------------------------------
subtest dependency_skip

statement ok
CREATE TABLE dep_table (x INT)

statement ok
CREATE USER dep_user PROVISIONSRC 'ldap:ldap.example.com'

statement ok
GRANT ALL ON TABLE dep_table TO dep_user

statement ok
DROP PROVISIONED ROLES WITH SOURCE = 'ldap:ldap.example.com'

# dep_user should still exist because it has grants on foo.
query T
SELECT username FROM system.users WHERE username = 'dep_user'
----
dep_user

# Clean up: revoke grants and drop.
statement ok
REVOKE ALL ON TABLE dep_table FROM dep_user

statement ok
DROP PROVISIONED ROLES WITH SOURCE = 'ldap:ldap.example.com'

query T
SELECT username FROM system.users WHERE username = 'dep_user'
----

subtest end

