# LogicTest: local

# Tests for DROP PROVISIONED ROLES statement.

# ----------------------------------------------------------------------
# Setup: create provisioned users with different sources and login times.
# ----------------------------------------------------------------------

statement ok
CREATE USER ldap_user1 PROVISIONSRC 'ldap:ldap.example.com'

statement ok
CREATE USER ldap_user2 PROVISIONSRC 'ldap:ldap.example.com'

statement ok
CREATE USER ldap_user3 PROVISIONSRC 'ldap:ldap.example.com'

statement ok
CREATE USER oidc_user1 PROVISIONSRC 'oidc:okta.corp.com'

statement ok
CREATE USER oidc_user2 PROVISIONSRC 'oidc:okta.corp.com'

statement ok
CREATE USER regular_user

# Set estimated_last_login_time for time-based filtering tests.
statement ok
UPDATE system.users SET estimated_last_login_time = '2024-01-15'::TIMESTAMPTZ
WHERE username IN ('ldap_user1', 'ldap_user2')

statement ok
UPDATE system.users SET estimated_last_login_time = '2025-12-01'::TIMESTAMPTZ
WHERE username IN ('ldap_user3', 'oidc_user1', 'oidc_user2')

# Verify setup: all users exist.
query T rowsort
SELECT username FROM system.users
WHERE username NOT IN ('root', 'admin', 'node')
----
ldap_user1
ldap_user2
ldap_user3
oidc_user1
oidc_user2
regular_user
testuser

# ----------------------------------------------------------------------
# Test 1: Non-provisioned users are never touched.
# ----------------------------------------------------------------------
subtest non_provisioned_untouched

statement ok
DROP PROVISIONED ROLES

# regular_user has no PROVISIONSRC, so it must survive.
query T
SELECT username FROM system.users WHERE username = 'regular_user'
----
regular_user

# testuser also survives.
query T
SELECT username FROM system.users WHERE username = 'testuser'
----
testuser

subtest end

# ----------------------------------------------------------------------
# Recreate provisioned users for subsequent tests.
# ----------------------------------------------------------------------

statement ok
CREATE USER ldap_user1 PROVISIONSRC 'ldap:ldap.example.com'

statement ok
CREATE USER ldap_user2 PROVISIONSRC 'ldap:ldap.example.com'

statement ok
CREATE USER ldap_user3 PROVISIONSRC 'ldap:ldap.example.com'

statement ok
CREATE USER oidc_user1 PROVISIONSRC 'oidc:okta.corp.com'

statement ok
CREATE USER oidc_user2 PROVISIONSRC 'oidc:okta.corp.com'

statement ok
UPDATE system.users SET estimated_last_login_time = '2024-01-15'::TIMESTAMPTZ
WHERE username IN ('ldap_user1', 'ldap_user2')

statement ok
UPDATE system.users SET estimated_last_login_time = '2025-12-01'::TIMESTAMPTZ
WHERE username IN ('ldap_user3', 'oidc_user1', 'oidc_user2')

# ----------------------------------------------------------------------
# Test 2: SOURCE filter drops only matching source.
# ----------------------------------------------------------------------
subtest source_filter

statement ok
DROP PROVISIONED ROLES WITH SOURCE = 'oidc:okta.corp.com'

# OIDC users should be gone.
query T
SELECT username FROM system.users WHERE username LIKE 'oidc_%'
----

# LDAP users should still exist.
query T rowsort
SELECT username FROM system.users WHERE username LIKE 'ldap_%'
----
ldap_user1
ldap_user2
ldap_user3

subtest end

# ----------------------------------------------------------------------
# Test 3: LIMIT clause caps the number of dropped users.
# ----------------------------------------------------------------------
subtest limit_clause

query I
SELECT count(*) FROM system.users WHERE username LIKE 'ldap_%'
----
3

statement ok
DROP PROVISIONED ROLES WITH SOURCE = 'ldap:ldap.example.com' LIMIT 1

# At most 1 user was dropped, so at least 2 remain.
query B
SELECT count(*) >= 2 FROM system.users WHERE username LIKE 'ldap_%'
----
true

subtest end

# Drop remaining LDAP users to clean up.
statement ok
DROP PROVISIONED ROLES WITH SOURCE = 'ldap:ldap.example.com'

query T
SELECT username FROM system.users WHERE username LIKE 'ldap_%'
----

# ----------------------------------------------------------------------
# Test 4: LAST LOGIN BEFORE filter.
# ----------------------------------------------------------------------
subtest time_filter

# Recreate users with different login times.
statement ok
CREATE USER time_old PROVISIONSRC 'ldap:ldap.example.com'

statement ok
CREATE USER time_recent PROVISIONSRC 'ldap:ldap.example.com'

statement ok
UPDATE system.users SET estimated_last_login_time = '2024-01-15'::TIMESTAMPTZ
WHERE username = 'time_old'

statement ok
UPDATE system.users SET estimated_last_login_time = '2026-03-01'::TIMESTAMPTZ
WHERE username = 'time_recent'

statement ok
DROP PROVISIONED ROLES WITH SOURCE = 'ldap:ldap.example.com',
  LAST LOGIN BEFORE '2025-01-01'

# time_old should be dropped (login before 2025-01-01).
query T
SELECT username FROM system.users WHERE username = 'time_old'
----

# time_recent should survive (login after 2025-01-01).
query T
SELECT username FROM system.users WHERE username = 'time_recent'
----
time_recent

statement ok
DROP PROVISIONED ROLES WITH SOURCE = 'ldap:ldap.example.com'

subtest end

