# Simple chain: A <- B <- C
discover
CREATE TABLE a (id INT PRIMARY KEY, val STRING);
CREATE TABLE b (id INT PRIMARY KEY, a_id INT NOT NULL REFERENCES a(id));
CREATE TABLE c (id INT PRIMARY KEY, b_id INT NOT NULL REFERENCES b(id))
----
----
table a
  columns: [id (not null), val]
  primary: a_pkey [id]
  referenced by: b_a_id_fkey b(a_id)

table b
  columns: [id (not null), a_id (not null)]
  primary: b_pkey [id]
  fk: b_a_id_fkey b(a_id) -> a(id)
  referenced by: c_b_id_fkey c(b_id)

table c
  columns: [id (not null), b_id (not null)]
  primary: c_pkey [id]
  fk: c_b_id_fkey c(b_id) -> b(id)
----
----

