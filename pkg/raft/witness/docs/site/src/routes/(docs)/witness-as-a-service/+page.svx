  const progressTrackerUrl = sourceUrl('pkg/raft/tracker/progresstracker.go', 31);
  const tickHeartbeatUrl = sourceUrl('pkg/raft/raft.go', 1209, 1210);
  const bcastFortifyUrl = sourceUrl('pkg/raft/raft.go', 901, 904);
  const fortTrackerIsFortifiedByUrl = sourceUrl('pkg/raft/tracker/fortificationtracker.go', 162, 186);
