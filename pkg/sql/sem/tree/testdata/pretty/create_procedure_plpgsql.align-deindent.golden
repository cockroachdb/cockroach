CREATE PROCEDURE transfer(
	from_id INT8,
	to_id INT8,
	amount DECIMAL
)
	LANGUAGE plpgsql
	AS $funcbodyx$
		BEGIN
			IF amount
			<= 0 THEN
				RAISE EXCEPTION
					'amount must be positive';
			END IF;
			UPDATE
				accounts
			SET
				balance
					= balance
					- amount
			WHERE
				id
				= from_id;
			UPDATE
				accounts
			SET
				balance
					= balance
					+ amount
			WHERE
				id
				= to_id;
			DO $funcbody$
				BEGIN
					RAISE NOTICE
						'done';
					DO $$
						BEGIN
							RAISE NOTICE
								'inner';
						END;
					$$;
				END;
			$funcbody$;
		END;
