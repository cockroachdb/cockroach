CREATE OR REPLACE FUNCTION get_top_orders(
	min_amount DECIMAL,
	lim INT8
)
	RETURNS SETOF INT8
	STABLE
	LANGUAGE SQL
	AS $funcbodyx$
		WITH
			filtered
				AS (
					SELECT
						id,
						amount
					FROM
						orders
					WHERE
						amount
						> min_amount
						AND status
							= 'active'
				)
		SELECT
			id
		FROM
			filtered
		ORDER BY
			amount
				DESC
		LIMIT
			lim;
