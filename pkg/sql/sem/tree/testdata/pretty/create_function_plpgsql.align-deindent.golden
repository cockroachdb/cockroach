CREATE FUNCTION fizzbuzz(
	n INT8
)
	RETURNS STRING
	LANGUAGE plpgsql
	AS $funcbodyx$
		DECLARE
			result STRING :=
				'';
			i INT8;
			word STRING;
		BEGIN
			FOR i IN 1..n LOOP
				IF i
				> 1 THEN
					result :=
						result
						|| ' ';
				END IF;
				word :=
					'';
				IF i
				% 3
				= 0 THEN
					word :=
						word
						|| 'Fizz';
				END IF;
				IF i
				% 5
				= 0 THEN
					word :=
						word
						|| 'Buzz';
				END IF;
				IF word
				= '' THEN
					word :=
						i::STRING;
				END IF;
				result :=
					result
					|| word;
			END LOOP;
			DO $funcbody$
				BEGIN
					RAISE NOTICE
						'done';
					DO $$
						BEGIN
							RAISE NOTICE
								'inner';
						END;
					$$;
				END;
			$funcbody$;
			RETURN
				result;
		END;
	$funcbodyx$

