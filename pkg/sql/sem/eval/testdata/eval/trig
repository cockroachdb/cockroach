# ── Inverse trig (radians) ──────────────────────────────────────────

eval
acos(0)
----
1.5707963267948966

eval
asin(1.0)
----
1.5707963267948966

# Boundary values: exactly -1 and 1 must succeed.

eval
asin(-1.0)
----
-1.5707963267948966

eval
acos(1.0)
----
0.0

eval
acos(-1.0)
----
3.141592653589793

# Domain errors for out-of-range inputs.

