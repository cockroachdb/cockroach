CREATE SCHEMA s;
CREATE TABLE s.t1 (id INT PRIMARY KEY);
CREATE TABLE s.t2 (id INT PRIMARY KEY);
CREATE FUNCTION s.f1() RETURNS TRIGGER LANGUAGE PLpgSQL AS $$
  BEGIN
    INSERT INTO s.t2 VALUES (1);
    RETURN NEW;
  END
$$;
CREATE FUNCTION s.f2() RETURNS TRIGGER LANGUAGE PLpgSQL AS $$
  BEGIN
    INSERT INTO s.t1 VALUES (1);
    RETURN NEW;
  END
$$;
CREATE TRIGGER tg1 AFTER INSERT ON s.t1 FOR EACH ROW EXECUTE FUNCTION s.f1();
CREATE TRIGGER tg2 AFTER INSERT ON s.t2 FOR EACH ROW EXECUTE FUNCTION s.f2();
