/* setup */
CREATE TABLE t(a INT PRIMARY KEY, b INT);
CREATE FUNCTION f_insert(a INT, b INT) RETURNS INT LANGUAGE SQL AS $$
  SELECT b;
  INSERT INTO t VALUES(a, b);
  SELECT a;
$$;

/* test */
EXPLAIN (DDL, SHAPE) CREATE FUNCTION f_caller(a INT, b INT) RETURNS INT LANGUAGE SQL AS $$
  SELECT f_insert(a, b);
$$;
