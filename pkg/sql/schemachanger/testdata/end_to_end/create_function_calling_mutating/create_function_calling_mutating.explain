/* setup */
CREATE TABLE t(a INT PRIMARY KEY, b INT);
CREATE FUNCTION f_insert(a INT, b INT) RETURNS VOID LANGUAGE SQL AS $$
  INSERT INTO t VALUES(a, b);
$$;

/* test */
EXPLAIN (DDL) CREATE FUNCTION f_caller(a INT, b INT) RETURNS VOID LANGUAGE SQL AS $$
  SELECT f_insert(a, b);
$$;
