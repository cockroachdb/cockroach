# ----------------------------------------------------------------------
# Test 9: Non-admin CREATEROLE caller skips admin provisioned users.
#
# A CREATEROLE user (without admin) should be able to run
# DROP PROVISIONED ROLES. Admin-role members that happen to be
# provisioned are silently skipped, while non-admin provisioned users
# are dropped. This diverges from DROP ROLE which would error.
# ----------------------------------------------------------------------
subtest admin_skip_non_admin_caller

# Create a provisioned user that is also an admin.
statement ok
CREATE USER admin_prov PROVISIONSRC 'ldap:ldap.example.com'

statement ok
GRANT admin TO admin_prov

# Create a non-admin provisioned user.
statement ok
CREATE USER nonadmin_prov PROVISIONSRC 'ldap:ldap.example.com'

# Give testuser CREATEROLE so it can run DROP PROVISIONED ROLES.
statement ok
ALTER ROLE testuser CREATEROLE

user testuser

# This should succeed — admin_prov is skipped, nonadmin_prov is dropped.
statement ok
DROP PROVISIONED ROLES WITH SOURCE = 'ldap:ldap.example.com' LIMIT 100

user root

# admin_prov must still exist (skipped because it has admin role).
query T
SELECT username FROM system.users WHERE username = 'admin_prov'
----
admin_prov

# nonadmin_prov must be dropped.
query T
SELECT username FROM system.users WHERE username = 'nonadmin_prov'
----

# Contrast with DROP ROLE: a non-admin caller would error on admin
# users rather than silently skipping them.
user testuser

statement error pq: must be superuser to drop superusers
DROP ROLE admin_prov

user root

# Clean up: revoke admin, remove CREATEROLE from testuser, then drop.
statement ok
REVOKE admin FROM admin_prov

statement ok
DROP ROLE admin_prov

statement ok
ALTER ROLE testuser NOCREATEROLE

subtest end

