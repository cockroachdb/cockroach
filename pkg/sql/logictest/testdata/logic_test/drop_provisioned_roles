# ----------------------------------------------------------------------
# Test 22: Expression evaluation for SOURCE and LAST LOGIN BEFORE.
#
# The grammar accepts a_expr for both SOURCE = <expr> and
# LAST LOGIN BEFORE <expr>. Expressions must be evaluated at execution
# time (not stringified), so concatenation, function calls, and
# interval arithmetic all work correctly.
# ----------------------------------------------------------------------
subtest expression_evaluation

# Setup: create provisioned users with different sources and login times.
statement ok
CREATE USER expr_alice PROVISIONSRC 'ldap:foo'

statement ok
CREATE USER expr_bob PROVISIONSRC 'ldap:bar'

statement ok
UPDATE system.users SET estimated_last_login_time = '2025-01-01 00:00:00+00'::TIMESTAMPTZ
WHERE username IN ('expr_alice', 'expr_bob')

# Confirm both users exist.
query T rowsort
SELECT username FROM system.users WHERE username IN ('expr_alice', 'expr_bob')
----
expr_alice
expr_bob

# --- SOURCE = <concatenation expression> ---
# ('ldap:' || 'foo') should evaluate to 'ldap:foo' and match expr_alice.
statement ok
DROP PROVISIONED ROLES WITH SOURCE = ('ldap:' || 'foo') LIMIT 100

# expr_alice should be dropped (source matched via expression evaluation).
query T rowsort
SELECT username FROM system.users WHERE username IN ('expr_alice', 'expr_bob')
----
expr_bob

# Recreate expr_alice for the next test.
statement ok
CREATE USER expr_alice PROVISIONSRC 'ldap:foo'

statement ok
UPDATE system.users SET estimated_last_login_time = '2025-01-01 00:00:00+00'::TIMESTAMPTZ
WHERE username = 'expr_alice'

# --- LAST LOGIN BEFORE <interval expression> ---
# (now() - '1 day'::interval) should evaluate to a concrete timestamp.
# Both users last logged in on 2025-01-01 which is well before yesterday,
# so both should be dropped.
statement ok
DROP PROVISIONED ROLES WITH SOURCE = 'ldap:foo',
  LAST LOGIN BEFORE (now() - '1 day'::INTERVAL) LIMIT 100

# expr_alice should be dropped (last login well before yesterday).
query T
SELECT username FROM system.users WHERE username = 'expr_alice'
----

# expr_bob should survive (different source, not matched).
query T
SELECT username FROM system.users WHERE username = 'expr_bob'
----
expr_bob

# --- LAST LOGIN BEFORE with expression that evaluates to future ---
# Recreate expr_alice to test that a future timestamp drops the user.
statement ok
CREATE USER expr_alice PROVISIONSRC 'ldap:foo'

statement ok
UPDATE system.users SET estimated_last_login_time = '2025-01-01 00:00:00+00'::TIMESTAMPTZ
WHERE username = 'expr_alice'

statement ok
DROP PROVISIONED ROLES WITH SOURCE = 'ldap:foo',
  LAST LOGIN BEFORE (now() + '1 day'::INTERVAL) LIMIT 100

# expr_alice should be dropped (login is before tomorrow).
query T
SELECT username FROM system.users WHERE username = 'expr_alice'
----

# Clean up.
statement ok
DROP PROVISIONED ROLES WITH SOURCE = 'ldap:bar' LIMIT 100

subtest end

