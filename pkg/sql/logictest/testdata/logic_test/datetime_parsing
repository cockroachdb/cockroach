# Julian day with W: W overrides the day from J.
query T
SELECT to_timestamp('72-3-2460389-FF1', 'FF2-W-J-"FF1"')::string
----
2024-03-15 00:00:00.72+00

# YYYY+YYY overlap: conflict detection uses the raw parsed value before
# adjust_partial_year_to_2020, so YYYY(2024) + YYY(024=24 raw) conflicts.
statement error conflicting values for "YYY" field
SELECT to_timestamp('2024024', 'YYYYYYY')::string

# DAY+DY overlap: PostgreSQL increments the d field after setting it,
# so duplicate day-of-week names always conflict.
statement error conflicting values for "DY" field
SELECT to_timestamp('WEDNESDAY-FEBRUARY /FEB WED', 'DAY-MONTH/MON DY')::string

# FF2+FF2 with non-zero values: conflict detection uses the raw parsed
# value before scaling to microseconds.
statement error conflicting values for "FF2" field
SELECT to_timestamp('313106', 'FF2FF2HH')::string

# DAY + D with matching day-of-week: DY sets d to 1-indexed value,
# D also stores 1-indexed, so matching values don't conflict.
query T
SELECT to_timestamp('SAT 7', 'DY D')::string
----
0001-01-01 00:00:00+00 BC

