# Regression tests: FF precision rounding.
# When FF is specified, to_timestamp rounds the fractional seconds
# to the FF precision, matching PostgreSQL's AdjustTimestampForTypmod.

# FF1 + MS: round to tenths of a second.
query T
SELECT to_timestamp('3783', 'MSFF1')::text
----
0001-01-01 00:00:00.7+00 BC

query T
SELECT to_timestamp('465-4', 'MS-FF1')::text
----
0001-01-01 00:00:00.9+00 BC

query T
SELECT to_timestamp('4.425JUN', 'FF1.MSMON')::text
----
0001-06-01 00:00:00.8+00 BC

# FF2 + MS: round to hundredths of a second.
query T
SELECT to_timestamp('49491', 'FF2MS')::text
----
0001-01-01 00:00:00.98+00 BC

# FF1 + MS order doesn't matter.
query T
SELECT to_timestamp('1378', 'FF1MS')::text
----
0001-01-01 00:00:00.5+00 BC

# FF4 with literal text: the "FF6" literal consumes input characters,
# and FF4 parses the remaining digits with precision rounding.
query T
SELECT to_timestamp('DECEMBER FF6 0000', 'MONTH"FF6" FF4')::text
----
0001-12-01 00:00:00.6+00 BC

# Regression tests: literal character handling.
# In non-FX mode, whitespace is only skipped before action (keyword)
# nodes, not before literal character nodes. Literals consume one input
# character each without checking for a match (matching PostgreSQL).

# DAY followed by quoted literal and YYY.
query T
SELECT to_timestamp('SATURDAY HH24021', 'DAY"HH24"YYY')::text
----
4021-01-01 00:00:00+00

query T
SELECT to_timestamp('SATURDAY HH24521', 'DAY"HH24"YYY')::text
----
4521-01-01 00:00:00+00

# DAY with no extra whitespace offset: parses correctly.
query T
SELECT to_timestamp('MONDAYHH24021', 'DAY"HH24"YYY')::text
----
2021-01-01 00:00:00+00

# MONTH followed by quoted literal and SS.
query T
SELECT to_timestamp('21AUGUST   .HH12D.44', 'CCMONTH."HH12""D".SS')::text
----
2001-08-01 00:00:12+00

# MONTH followed by quoted literal and CC.
query T
SELECT to_timestamp('JANUARY  HH12:24', 'MONTH"HH12":YY')::text
----
2012-01-01 00:00:00+00

