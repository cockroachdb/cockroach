# Duplicate format fields: PostgreSQL allows the same field to appear multiple
# times, only erroring when values conflict (non-zero and different).

# Same field repeated with same value.
query T
SELECT to_timestamp('0000', 'FF2FF2')::string
----
0001-01-01 00:00:00+00 BC

# AD and BC both set the bc field; same era is not a conflict.
query T
SELECT to_timestamp('AD AD', 'AD BC')::string
----
0001-01-01 00:00:00+00 BC

# HH and HH12 both set the hh field.
query T
SELECT to_timestamp('1212', 'HHHH12')::string
----
0001-01-01 00:00:00+00 BC

# YYYY and Y,YYY both set the year field; same value is not a conflict.
query T
SELECT to_timestamp('2,024:2024', 'Y,YYY:YYYY')::string
----
2024-01-01 00:00:00+00

# MON and MONTH both set the mm field; same month is not a conflict.
query T
SELECT to_timestamp('FEBFEBRUARY .02.12', 'MONMONTH.MM.HH12')::string
----
0001-02-01 00:00:00+00 BC

# RM and MON both set mm; same month is not a conflict.
query T
SELECT to_timestamp('VIII:08AUG', 'RM:YYMON')::string
----
2008-08-01 00:00:00+00

# Same field with same non-zero value is allowed.
query T
SELECT to_timestamp('16231623', 'YYYYYYYY')::string
----
1623-01-01 00:00:00+00

# Conflicting values for the same field should still error.
statement error conflicting values for "YYYY" field
SELECT to_timestamp('20232024', 'YYYYYYYY')::string

# FF and MS interaction: PostgreSQL makes MS and US additive.
query T
SELECT to_timestamp('13500/135', 'FF5/MS')::string
----
