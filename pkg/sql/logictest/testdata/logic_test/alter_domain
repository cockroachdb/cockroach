# LogicTest: local

# Test ALTER DOMAIN syntax. Tests are added as operations are implemented
# through the declarative schema changer.

statement ok
CREATE DOMAIN d AS INT DEFAULT 0 NOT NULL CHECK (VALUE > 0)

subtest set_default

statement error pgcode 0A000 ALTER DOMAIN SET DEFAULT is not supported
ALTER DOMAIN d SET DEFAULT 42

statement error pgcode 0A000 ALTER DOMAIN SET DEFAULT is not supported
ALTER DOMAIN d SET DEFAULT 1 + 2

subtest end

subtest drop_default

statement error pgcode 0A000 ALTER DOMAIN DROP DEFAULT is not supported
ALTER DOMAIN d DROP DEFAULT

subtest end

subtest set_not_null

statement ok
ALTER DOMAIN d SET NOT NULL

statement ok
CREATE DOMAIN d_nn AS INT DEFAULT 0

query T
SELECT conname FROM pg_constraint WHERE contypid = 'd_nn'::regtype AND contype = 'n' ORDER BY conname
----

statement ok
ALTER DOMAIN d_nn SET NOT NULL

# Verify the NOT NULL constraint exists.
query T
SELECT conname FROM pg_constraint WHERE contypid = 'd_nn'::regtype AND contype = 'n' ORDER BY conname
----
d_nn_not_null

statement ok
ALTER DOMAIN d_nn SET NOT NULL

# Verify there is exactly one NOT NULL constraint.
query T
SELECT conname FROM pg_constraint WHERE contypid = 'd_nn'::regtype AND contype = 'n' ORDER BY conname
----
d_nn_not_null

subtest end

subtest drop_not_null

statement ok
ALTER DOMAIN d_nn DROP NOT NULL

query T
SELECT conname FROM pg_constraint WHERE contypid = 'd_nn'::regtype AND contype = 'n' ORDER BY conname
----

statement ok
ALTER DOMAIN d_nn DROP NOT NULL

statement ok
DROP DOMAIN d_nn

subtest end

# Rolling back a SET NOT NULL transaction must leave the descriptor with no
# residual NOT NULL state.
subtest set_not_null_rollback_in_txn

statement ok
CREATE DOMAIN d_rb AS INT DEFAULT 0

statement ok
BEGIN;
ALTER DOMAIN d_rb SET NOT NULL;
ROLLBACK

query T
SELECT conname FROM pg_constraint WHERE contypid = 'd_rb'::regtype AND contype = 'n' ORDER BY conname
----

# The domain should still permit NULLs after the rollback.
statement ok
CREATE TABLE t_rb (c d_rb)

statement ok
INSERT INTO t_rb VALUES (NULL)

statement ok
DROP TABLE t_rb;
DROP DOMAIN d_rb

subtest end

# DROP NOT NULL followed by SET NOT NULL in the same transaction must produce a
# domain with the NOT NULL constraint present.
subtest drop_then_set_not_null_in_txn

statement ok
CREATE DOMAIN d_drop_set AS INT DEFAULT 0 NOT NULL

statement ok
BEGIN;
ALTER DOMAIN d_drop_set DROP NOT NULL;
ALTER DOMAIN d_drop_set SET NOT NULL;
COMMIT

query T
SELECT conname FROM pg_constraint WHERE contypid = 'd_drop_set'::regtype AND contype = 'n' ORDER BY conname
----
d_drop_set_not_null

statement ok
DROP DOMAIN d_drop_set

subtest end

# A SET NOT NULL added after a previous DROP NOT NULL committed must use a
# fresh constraint ID instead of reusing the dropped one. We can't compare
# pg_constraint OIDs because they are hashes of (typeOid, constraintID) and
# don't preserve ordering; read the underlying notNullConstraintId from the
# domain descriptor directly instead.
subtest not_null_constraint_id_monotonic

statement ok
CREATE DOMAIN d_ids AS INT DEFAULT 0

statement ok
ALTER DOMAIN d_ids SET NOT NULL

let $first_id
SELECT (descriptor->'type'->'domain'->>'notNullConstraintId')::int
FROM crdb_internal.kv_catalog_descriptor WHERE id = ('d_ids'::regtype::oid::int - 100000)

statement ok
ALTER DOMAIN d_ids DROP NOT NULL

statement ok
ALTER DOMAIN d_ids SET NOT NULL

query B
SELECT (SELECT (descriptor->'type'->'domain'->>'notNullConstraintId')::int
        FROM crdb_internal.kv_catalog_descriptor WHERE id = ('d_ids'::regtype::oid::int - 100000)) > $first_id
----
true

statement ok
DROP DOMAIN d_ids

subtest end

