# LogicTest: !3node-tenant-default-configs !local-mixed-25.4 !local-mixed-26.1 !local-mixed-26.2

# crdb_internal.tsdb_query is a privilege-gated generator that returns
# raw per-source datapoints from the in-cluster TSDB. The asserts below
# focus on the schema, argument validation, and access control. End-to-
# end coverage that round-trips a written datapoint through the bridge
# lives in pkg/ts/sql_adapter_e2e_test.go.

# Schema: a labelled tuple of (timestamp, value, source).
query TFT colnames
SELECT * FROM crdb_internal.tsdb_query(
  'cr.node.sql.query.count',
  '2026-05-01 00:00:00+00'::timestamptz,
  '2026-05-01 00:00:01+00'::timestamptz
) LIMIT 0
----
timestamp  value  source

# An unknown metric name returns zero rows (not an error).
query TFT
SELECT * FROM crdb_internal.tsdb_query(
  'cr.node.does_not_exist',
  '2026-05-01 00:00:00+00'::timestamptz,
  '2026-05-01 00:00:01+00'::timestamptz
)
----

# end_time must be strictly greater than start_time.
query error pq: crdb_internal.tsdb_query end_time .* must be greater than start_time
SELECT * FROM crdb_internal.tsdb_query(
  'cr.node.sql.query.count',
  '2026-05-01 00:00:00+00'::timestamptz,
  '2026-05-01 00:00:00+00'::timestamptz
)

# A NULL name argument is rejected by the typing layer (calledOnNullInput
# defaults to false for generators); the underlying generator is never
# constructed.
query TFT
SELECT * FROM crdb_internal.tsdb_query(
  NULL,
  '2026-05-01 00:00:00+00'::timestamptz,
  '2026-05-01 00:00:01+00'::timestamptz
)
----

# A future-only window is clamped to "now" by the adapter, so the call
# returns zero rows rather than erroring.
query TFT
SELECT * FROM crdb_internal.tsdb_query(
  'cr.node.sql.query.count',
  '2999-01-01 00:00:00+00'::timestamptz,
  '2999-01-01 00:00:01+00'::timestamptz
)
----

# PREPARE/EXECUTE with placeholders for all three arguments.
statement ok
PREPARE p AS
  SELECT * FROM crdb_internal.tsdb_query($1, $2, $3) LIMIT 0

query TFT colnames
EXECUTE p('cr.node.sql.query.count',
          '2026-05-01 00:00:00+00'::timestamptz,
          '2026-05-01 00:00:01+00'::timestamptz)
----
timestamp  value  source

# Privilege denial: a non-admin without VIEWCLUSTERMETADATA cannot call
# the generator. The default test fixture creates `testuser` without
# any system privileges. Switch users, expect an insufficient_privilege
# error, then GRANT the privilege and confirm the call succeeds.
user testuser

query error pq: user testuser does not have VIEWCLUSTERMETADATA system privilege
SELECT * FROM crdb_internal.tsdb_query(
  'cr.node.sql.query.count',
  '2026-05-01 00:00:00+00'::timestamptz,
  '2026-05-01 00:00:01+00'::timestamptz
)

user root

statement ok
GRANT SYSTEM VIEWCLUSTERMETADATA TO testuser

user testuser

query TFT
SELECT * FROM crdb_internal.tsdb_query(
  'cr.node.does_not_exist',
  '2026-05-01 00:00:00+00'::timestamptz,
  '2026-05-01 00:00:01+00'::timestamptz
)
----

user root
