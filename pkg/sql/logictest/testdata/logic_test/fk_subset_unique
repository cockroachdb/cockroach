# LogicTest: default-configs 3node-tenant !local-mixed-25.4 !local-mixed-26.1 !local-mixed-26.2

# Foreign keys backed by a unique constraint covering only a subset of the
# referenced columns (CockroachDB extension; gated by
# require_fk_unique_constraint_on_all_columns). This feature is gated on
# cluster version V26_3, so the tests are excluded from the local-mixed-*
# configs where the cluster has not yet finalized to V26_3.

# Creation, notice, basic DML enforcement, and edge cases for what counts
# as a valid subset backing.
subtest subset_unique_backing

statement ok
CREATE TABLE subset_parent (a INT PRIMARY KEY, b INT, c INT)

statement ok
INSERT INTO subset_parent VALUES (1, 10, 100), (2, 20, 200), (3, 30, 300)

# Default behavior: a unique constraint on a subset of the referenced columns
# is accepted with a NOTICE. Here parent has UNIQUE(a) (the primary key) and
# the FK references (a, b, c).

skipif config weak-iso-level-configs
query T noticetrace
CREATE TABLE subset_child (
  a INT, b INT, c INT,
  FOREIGN KEY (a, b, c) REFERENCES subset_parent (a, b, c)
)
----
NOTICE: foreign key "subset_child_a_b_c_fkey" is currently backed by a unique constraint that covers a subset of the referenced columns of subset_parent; this is a CockroachDB extension and may not be portable to other databases. Foreign key enforcement on insert may incur additional latency; consider adding a unique index matching all referenced columns, or (if applicable) extending the existing unique index to STORE the other referenced columns

onlyif config weak-iso-level-configs
statement ok
CREATE TABLE subset_child (
  a INT, b INT, c INT,
  FOREIGN KEY (a, b, c) REFERENCES subset_parent (a, b, c)
)

# Insert satisfying the FK should succeed.
statement ok
INSERT INTO subset_child VALUES (1, 10, 100), (2, 20, 200)

# Insert with non-existent parent key (a) should fail.
statement error pq: insert on table "subset_child" violates foreign key constraint
INSERT INTO subset_child VALUES (99, 0, 0)

# Insert where parent key matches but extra columns don't should also fail —
# the extra columns are enforced as implicit equality conditions.
statement error pq: insert on table "subset_child" violates foreign key constraint
INSERT INTO subset_child VALUES (1, 999, 100)

statement error pq: insert on table "subset_child" violates foreign key constraint
INSERT INTO subset_child VALUES (1, 10, 999)

# Update on the child that violates the FK should fail.
statement error pq: update on table "subset_child" violates foreign key constraint
UPDATE subset_child SET b = 999 WHERE a = 1

# Delete from parent should be blocked by RESTRICT-by-default.
statement error pq: delete on table "subset_parent" violates foreign key constraint
DELETE FROM subset_parent WHERE a = 1

statement ok
DROP TABLE subset_child, subset_parent

# Same as above, but via ALTER TABLE ADD CONSTRAINT (exercises the
# declarative schema changer path).
statement ok
CREATE TABLE subset_parent (a INT PRIMARY KEY, b INT, c INT);
CREATE TABLE subset_child (a INT, b INT, c INT)

skipif config weak-iso-level-configs
query T noticetrace
ALTER TABLE subset_child ADD CONSTRAINT subset_fk FOREIGN KEY (a, b, c) REFERENCES subset_parent (a, b, c)
----
NOTICE: foreign key "subset_fk" is currently backed by a unique constraint that covers a subset of the referenced columns of subset_parent; this is a CockroachDB extension and may not be portable to other databases. Foreign key enforcement on insert may incur additional latency; consider adding a unique index matching all referenced columns, or (if applicable) extending the existing unique index to STORE the other referenced columns

onlyif config weak-iso-level-configs
statement ok
ALTER TABLE subset_child ADD CONSTRAINT subset_fk FOREIGN KEY (a, b, c) REFERENCES subset_parent (a, b, c)

# pg_constraint should surface the chosen backing constraint's OID (here, the
# parent's PK) in conindid, rather than 0. Confirms the introspection path
# falls back to the subset finder for subset FKs.
query B
SELECT conindid != 0
  FROM pg_catalog.pg_constraint
 WHERE conname = 'subset_fk'
----
true

statement ok
DROP TABLE subset_child, subset_parent

# Exact-match FKs should NOT emit a notice (regression check that we only
# warn on the strict-subset case).
statement ok
CREATE TABLE exact_parent (a INT, b INT, PRIMARY KEY (a, b))

skipif config weak-iso-level-configs
query T noticetrace
CREATE TABLE exact_child (
  a INT, b INT,
  FOREIGN KEY (a, b) REFERENCES exact_parent (a, b)
)
----

onlyif config weak-iso-level-configs
statement ok
CREATE TABLE exact_child (
  a INT, b INT,
  FOREIGN KEY (a, b) REFERENCES exact_parent (a, b)
)

statement ok
DROP TABLE exact_child, exact_parent

# A unique constraint covering NONE of the referenced columns is still
# rejected — the relaxation requires a non-empty subset.
statement ok
CREATE TABLE no_overlap_parent (a INT PRIMARY KEY, b INT, c INT)

statement error there is no unique constraint matching given keys for referenced table no_overlap_parent
CREATE TABLE no_overlap_child (
  b INT, c INT,
  FOREIGN KEY (b, c) REFERENCES no_overlap_parent (b, c)
)

statement ok
DROP TABLE no_overlap_parent

# Partial unique indexes are still NOT eligible to back a subset FK.
statement ok
SET experimental_enable_unique_without_index_constraints = true

statement ok
CREATE TABLE partial_subset_parent (
  a INT, b INT,
  UNIQUE INDEX (a) WHERE b > 0
)

statement error there is no unique constraint matching given keys for referenced table partial_subset_parent
CREATE TABLE partial_subset_child (
  a INT, b INT,
  FOREIGN KEY (a, b) REFERENCES partial_subset_parent (a, b)
)

statement ok
DROP TABLE partial_subset_parent

statement ok
RESET experimental_enable_unique_without_index_constraints

subtest end

# SHOW CREATE TABLE round-trip and catalog back-reference protections for
# subset FKs.
subtest subset_unique_catalog

# SHOW CREATE TABLE round-trip: subset FKs should serialize as a plain
# FOREIGN KEY clause with no special markers indicating subset-cover backing.
statement ok
CREATE TABLE show_p (a INT PRIMARY KEY, b INT, c INT)

statement ok
CREATE TABLE show_c (
  a INT NOT NULL, b INT NOT NULL, c INT NOT NULL,
  CONSTRAINT show_fk FOREIGN KEY (a, b, c) REFERENCES show_p (a, b, c),
  FAMILY f1 (a, b, c)
)

onlyif config schema-locked-disabled
query TT
SHOW CREATE TABLE show_c
----
show_c  CREATE TABLE public.show_c (
          a INT8 NOT NULL,
          b INT8 NOT NULL,
          c INT8 NOT NULL,
          rowid INT8 NOT VISIBLE NOT NULL DEFAULT unique_rowid(),
          CONSTRAINT show_c_pkey PRIMARY KEY (rowid ASC),
          CONSTRAINT show_fk FOREIGN KEY (a, b, c) REFERENCES public.show_p(a, b, c),
          FAMILY f1 (a, b, c, rowid)
        );

skipif config schema-locked-disabled
query TT
SHOW CREATE TABLE show_c
----
show_c  CREATE TABLE public.show_c (
          a INT8 NOT NULL,
          b INT8 NOT NULL,
          c INT8 NOT NULL,
          rowid INT8 NOT VISIBLE NOT NULL DEFAULT unique_rowid(),
          CONSTRAINT show_c_pkey PRIMARY KEY (rowid ASC),
          CONSTRAINT show_fk FOREIGN KEY (a, b, c) REFERENCES public.show_p(a, b, c),
          FAMILY f1 (a, b, c, rowid)
        ) WITH (schema_locked = true);

statement ok
DROP TABLE show_c, show_p

# Dropping the unique constraint that backs a subset FK should fail because
# of the catalog back-reference. Same protection that applies to exact-match
# FKs — the subset extension must not bypass it.
statement ok
CREATE TABLE drop_p (id INT PRIMARY KEY, b INT, c INT, CONSTRAINT u_c UNIQUE (c))

statement ok
CREATE TABLE drop_c (
  b INT NOT NULL, c INT NOT NULL,
  CONSTRAINT drop_fk FOREIGN KEY (b, c) REFERENCES drop_p (b, c)
)

skipif config local-legacy-schema-changer
statement error pq: .* is referenced by foreign key
ALTER TABLE drop_p DROP CONSTRAINT u_c

statement ok
DROP TABLE drop_c, drop_p

# Conversely, when the parent has multiple constraints that can subset-back
# the FK, dropping one of them should succeed without CASCADE — the other
# remains as a viable replacement backing.
statement ok
CREATE TABLE replace_p (
  a INT PRIMARY KEY,
  b INT,
  CONSTRAINT u_b UNIQUE (b)
)

statement ok
CREATE TABLE replace_c (
  a INT NOT NULL, b INT NOT NULL,
  CONSTRAINT replace_fk FOREIGN KEY (a, b) REFERENCES replace_p (a, b)
)

# Both UNIQUE(b) and PRIMARY KEY(a) subset-cover the FK on (a, b). Dropping
# u_b leaves the PK as a viable replacement; the drop should succeed.
skipif config local-legacy-schema-changer
statement ok
ALTER TABLE replace_p DROP CONSTRAINT u_b

# FK is still enforced after the drop, now backed solely by the PK.
statement ok
INSERT INTO replace_p VALUES (1, 10)

statement ok
INSERT INTO replace_c VALUES (1, 10)

statement error pq: .* violates foreign key constraint
INSERT INTO replace_c VALUES (99, 0)

statement ok
DROP TABLE replace_c, replace_p

subtest end

# UPSERT / INSERT ... ON CONFLICT goes through a different mutation path than
# plain INSERT/UPDATE. Verify the subset FK is enforced for both the insert
# and the conflict-update branches.
subtest subset_unique_upsert

statement ok
CREATE TABLE upsert_p (a INT PRIMARY KEY, b INT, c INT)

statement ok
INSERT INTO upsert_p VALUES (1, 10, 100), (2, 20, 200)

statement ok
CREATE TABLE upsert_c (
  cid INT PRIMARY KEY,
  a INT NOT NULL, b INT NOT NULL, c INT NOT NULL,
  CONSTRAINT upsert_fk FOREIGN KEY (a, b, c) REFERENCES upsert_p (a, b, c)
)

# UPSERT inserting a valid row succeeds (insert branch).
statement ok
INSERT INTO upsert_c (cid, a, b, c) VALUES (1, 1, 10, 100)
ON CONFLICT (cid) DO UPDATE SET a = excluded.a, b = excluded.b, c = excluded.c

# UPSERT inserting a row that violates the FK should fail (insert branch).
statement error pq: .* violates foreign key constraint
INSERT INTO upsert_c (cid, a, b, c) VALUES (2, 99, 0, 0)
ON CONFLICT (cid) DO UPDATE SET a = excluded.a, b = excluded.b, c = excluded.c

# UPSERT updating to a value that violates the FK should fail
# (conflict-update branch); cid=1 already exists, so this hits ON CONFLICT.
statement error pq: .* violates foreign key constraint
INSERT INTO upsert_c (cid, a, b, c) VALUES (1, 99, 0, 0)
ON CONFLICT (cid) DO UPDATE SET a = excluded.a, b = excluded.b, c = excluded.c

# UPSERT that mismatches only on the non-unique-backed column also fails —
# proves the residual equality is enforced on the UPSERT path too.
statement error pq: .* violates foreign key constraint
INSERT INTO upsert_c (cid, a, b, c) VALUES (1, 1, 999, 100)
ON CONFLICT (cid) DO UPDATE SET a = excluded.a, b = excluded.b, c = excluded.c

statement ok
DROP TABLE upsert_c, upsert_p

subtest end

