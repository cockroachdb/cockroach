subtest end

# UPSERT / INSERT ... ON CONFLICT goes through a different mutation path than
# plain INSERT/UPDATE. Verify the subset FK is enforced for both the insert
# and the conflict-update branches.
subtest subset_unique_upsert

statement ok
CREATE TABLE upsert_p (a INT PRIMARY KEY, b INT, c INT)

statement ok
INSERT INTO upsert_p VALUES (1, 10, 100), (2, 20, 200)

statement ok
CREATE TABLE upsert_c (
  cid INT PRIMARY KEY,
  a INT NOT NULL, b INT NOT NULL, c INT NOT NULL,
  CONSTRAINT upsert_fk FOREIGN KEY (a, b, c) REFERENCES upsert_p (a, b, c)
)

# UPSERT inserting a valid row succeeds (insert branch).
statement ok
INSERT INTO upsert_c (cid, a, b, c) VALUES (1, 1, 10, 100)
ON CONFLICT (cid) DO UPDATE SET a = excluded.a, b = excluded.b, c = excluded.c

# UPSERT inserting a row that violates the FK should fail (insert branch).
statement error pq: .* violates foreign key constraint
INSERT INTO upsert_c (cid, a, b, c) VALUES (2, 99, 0, 0)
ON CONFLICT (cid) DO UPDATE SET a = excluded.a, b = excluded.b, c = excluded.c

# UPSERT updating to a value that violates the FK should fail
# (conflict-update branch); cid=1 already exists, so this hits ON CONFLICT.
statement error pq: .* violates foreign key constraint
INSERT INTO upsert_c (cid, a, b, c) VALUES (1, 99, 0, 0)
ON CONFLICT (cid) DO UPDATE SET a = excluded.a, b = excluded.b, c = excluded.c

# UPSERT that mismatches only on the non-unique-backed column also fails
# proving the residual equality is enforced on the UPSERT path too.
statement error pq: .* violates foreign key constraint
INSERT INTO upsert_c (cid, a, b, c) VALUES (1, 1, 999, 100)
ON CONFLICT (cid) DO UPDATE SET a = excluded.a, b = excluded.b, c = excluded.c

statement ok
DROP TABLE upsert_c, upsert_p

subtest end

# NOT VALID + VALIDATE flow on subset FKs, including verification that the
# validation query enforces equality on all referenced columns (not just the
# unique-backed subset).
subtest subset_unique_validation

statement ok
CREATE TABLE notvalid_parent (a INT PRIMARY KEY, b INT);
CREATE TABLE notvalid_child (a INT, b INT);
INSERT INTO notvalid_parent VALUES (1, 10), (2, 20);
INSERT INTO notvalid_child VALUES (1, 10), (2, 20)

statement ok
ALTER TABLE notvalid_child ADD CONSTRAINT notvalid_fk FOREIGN KEY (a, b) REFERENCES notvalid_parent (a, b) NOT VALID

statement ok
ALTER TABLE notvalid_child VALIDATE CONSTRAINT notvalid_fk

# Drop the FK, insert a row that mismatches on the non-unique column, then
# re-add as NOT VALID and confirm VALIDATE catches the mismatch (proving the
# validation query enforces equality on all referenced columns, not just the
# unique-backed ones).
statement ok
ALTER TABLE notvalid_child DROP CONSTRAINT notvalid_fk

statement ok
INSERT INTO notvalid_child VALUES (1, 999)

statement ok
ALTER TABLE notvalid_child ADD CONSTRAINT notvalid_fk FOREIGN KEY (a, b) REFERENCES notvalid_parent (a, b) NOT VALID

statement error pgcode 23503 foreign key violation: "notvalid_child" row a=1, b=999, rowid=[0-9]+ has no match in "notvalid_parent"
ALTER TABLE notvalid_child VALIDATE CONSTRAINT notvalid_fk

