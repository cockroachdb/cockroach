----
drop_ref_child  drop_ref_child_pkey            PRIMARY KEY  PRIMARY KEY (rowid ASC)  true
drop_ref_child  drop_ref_child_rowid_not_null  NOT NULL     NOT NULL                 true

statement ok
DROP TABLE drop_ref_child, drop_ref_parent

