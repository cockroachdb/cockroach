skipif config local-legacy-schema-changer
statement error pq: .* is referenced by foreign key
ALTER TABLE drop_uwoi_p DROP CONSTRAINT u_c

statement ok
DROP TABLE drop_uwoi_c, drop_uwoi_p

statement ok
