# Verify that the sql.subset_unique_fks.enabled cluster setting can disable
# new subset-unique FK creation, that the error includes a hint pointing at
# the setting, and that flipping the setting off does NOT affect existing
# subset-unique FKs. Specifically, lookups that resolve an existing FK's
# backing unique constraint must keep honoring subset matching: DML
# enforcement on the child still validates, and a parent-side DROP
# CONSTRAINT on the backing unique still discovers the FK as a dependent.
subtest subset_unique_cluster_setting

statement ok
CREATE TABLE setting_parent (a INT PRIMARY KEY, b INT, c INT, UNIQUE (b))

statement ok
INSERT INTO setting_parent VALUES (1, 10, 100), (2, 20, 200)

# Create a subset-unique FK while the setting is at its default (true).
statement ok
CREATE TABLE setting_child_existing (
  b INT, c INT,
  CONSTRAINT subset_unique_fk FOREIGN KEY (b, c) REFERENCES setting_parent (b, c) ON DELETE CASCADE
)

statement ok
INSERT INTO setting_child_existing VALUES (10, 100), (20, 200)

# Disable the relaxation.
statement ok
SET CLUSTER SETTING sql.subset_unique_fks.enabled = false

# CREATE TABLE: a new subset-unique FK is rejected, with a hint that names
# the cluster setting so users can discover the gate.
statement error there is no unique constraint matching given keys for referenced table setting_parent\nHINT:.*sql\.subset_unique_fks\.enabled
CREATE TABLE setting_child_new (
  b INT, c INT,
  FOREIGN KEY (b, c) REFERENCES setting_parent (b, c)
)

# ALTER TABLE ADD CONSTRAINT: same gate via the declarative path.
statement ok
CREATE TABLE setting_child_new (b INT, c INT)

statement error there is no unique constraint matching given keys for referenced table setting_parent\nHINT:.*sql\.subset_unique_fks\.enabled
ALTER TABLE setting_child_new
  ADD CONSTRAINT new_fk FOREIGN KEY (b, c) REFERENCES setting_parent (b, c)

# Exact-match FKs are unaffected by the setting.
statement ok
ALTER TABLE setting_child_new
  ADD CONSTRAINT exact_fk FOREIGN KEY (b) REFERENCES setting_parent (b)

# Drop setting_child_new now so that the DROP CONSTRAINT test below has
# only subset_unique_fk (the subset-unique FK we want to exercise) depending
# on the parent's UNIQUE(b).
statement ok
DROP TABLE setting_child_new

# Existing subset-unique FK still validates DML even with the setting off.
statement error pq: insert on table "setting_child_existing" violates foreign key constraint
INSERT INTO setting_child_existing VALUES (99, 0)

statement error pq: update on table "setting_child_existing" violates foreign key constraint
UPDATE setting_child_existing SET b = 999 WHERE b = 10

# Existing subset-unique FK is still discovered as a back-reference when
# the parent row is deleted: ON DELETE CASCADE removes the corresponding
# child rows.
statement count 1
DELETE FROM setting_parent WHERE a = 1

query II rowsort
SELECT b, c FROM setting_child_existing
----
20  200

# Existing subset-unique FK is also discovered as a back-reference when
# the parent's backing unique is dropped. DROP INDEX CASCADE removes both
# the unique and the dependent FK; if the back-reference walker missed
# the FK, it would survive as a dangling reference. (DROP INDEX is used
# instead of ALTER TABLE DROP CONSTRAINT for compatibility with the
# legacy schema changer, which rejects DROP CONSTRAINT for unique
# constraints.)
#
# Confirm via information_schema that the FK is present before the DROP
# and absent after.
query I
SELECT count(*) FROM information_schema.referential_constraints
 WHERE constraint_name = 'subset_unique_fk'
----
1

statement ok
DROP INDEX setting_parent@setting_parent_b_key CASCADE

query I
SELECT count(*) FROM information_schema.referential_constraints
 WHERE constraint_name = 'subset_unique_fk'
----
0

statement ok
DROP TABLE setting_child_existing;
DROP TABLE setting_parent

statement ok
RESET CLUSTER SETTING sql.subset_unique_fks.enabled

subtest end
