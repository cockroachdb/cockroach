# NOT VALID + VALIDATE flow on subset FKs, including verification that the
# validation query enforces equality on all referenced columns (not just the
# unique-backed subset).
subtest subset_unique_validation

statement ok
CREATE TABLE notvalid_parent (a INT PRIMARY KEY, b INT);
CREATE TABLE notvalid_child (a INT, b INT);
INSERT INTO notvalid_parent VALUES (1, 10), (2, 20);
INSERT INTO notvalid_child VALUES (1, 10), (2, 20)

skipif config weak-iso-level-configs
query T noticetrace
ALTER TABLE notvalid_child ADD CONSTRAINT notvalid_fk FOREIGN KEY (a, b) REFERENCES notvalid_parent (a, b) NOT VALID
----
NOTICE: foreign key "notvalid_fk" is currently backed by a unique constraint that covers a subset of the referenced columns of notvalid_parent; this is a CockroachDB extension and may not be portable to other databases. Foreign key enforcement on insert may incur additional latency; consider adding a unique index matching all referenced columns, or (if applicable) extending the existing unique index to STORE the other referenced columns

onlyif config weak-iso-level-configs
statement ok
ALTER TABLE notvalid_child ADD CONSTRAINT notvalid_fk FOREIGN KEY (a, b) REFERENCES notvalid_parent (a, b) NOT VALID

statement ok
ALTER TABLE notvalid_child VALIDATE CONSTRAINT notvalid_fk

# Drop the FK, insert a row that mismatches on the non-unique column, then
# re-add as NOT VALID and confirm VALIDATE catches the mismatch (proving the
# validation query enforces equality on all referenced columns, not just the
# unique-backed ones).
statement ok
ALTER TABLE notvalid_child DROP CONSTRAINT notvalid_fk

statement ok
INSERT INTO notvalid_child VALUES (1, 999)

statement ok
ALTER TABLE notvalid_child ADD CONSTRAINT notvalid_fk FOREIGN KEY (a, b) REFERENCES notvalid_parent (a, b) NOT VALID

statement error pgcode 23503 foreign key violation: "notvalid_child" row a=1, b=999, rowid=[0-9]+ has no match in "notvalid_parent"
ALTER TABLE notvalid_child VALIDATE CONSTRAINT notvalid_fk

statement ok
DROP TABLE notvalid_child, notvalid_parent

subtest end

# Cascade and inbound-FK-trigger behavior on subset FKs. Specifically verifies
# that the trigger fires correctly when a parent UPDATE changes a referenced
# column that is NOT covered by the unique constraint backing the FK — a case
# that didn't exist pre-subset-matching (where all referenced cols had to be
# unique-backed).
subtest subset_unique_cascade

# ON DELETE CASCADE works on subset FKs.
statement ok
CREATE TABLE cascade_parent (a INT PRIMARY KEY, b INT, c INT)

statement ok
CREATE TABLE cascade_child (
  a INT, b INT, c INT,
  FOREIGN KEY (a, b, c) REFERENCES cascade_parent (a, b, c) ON DELETE CASCADE
)

statement ok
INSERT INTO cascade_parent VALUES (1, 10, 100), (2, 20, 200)

statement ok
INSERT INTO cascade_child VALUES (1, 10, 100), (2, 20, 200)

statement count 1
DELETE FROM cascade_parent WHERE a = 1

query III rowsort
SELECT a, b, c FROM cascade_child
----
2  20  200

statement ok
DROP TABLE cascade_child, cascade_parent

# Parent UPDATE on a non-unique-backed referenced column must still fire the
# inbound FK trigger. With subset matching, the parent's unique constraint
# covers only some referenced cols (here, just (a)); the trigger logic must
# key on the FK's full ReferencedColumnIDs, not the unique-backed subset, or
# we'd silently let parent updates break referential integrity.

statement ok
CREATE TABLE restrict_parent (a INT PRIMARY KEY, b INT)

statement ok
CREATE TABLE restrict_child (
  a INT, b INT,
  FOREIGN KEY (a, b) REFERENCES restrict_parent (a, b)
)

statement ok
INSERT INTO restrict_parent VALUES (1, 10), (2, 20)

statement ok
INSERT INTO restrict_child VALUES (1, 10), (2, 20)

# Updating the unique-backed col on parent must fail (no parent with new key).
statement error pq: update on table "restrict_parent" violates foreign key constraint
UPDATE restrict_parent SET a = 99 WHERE a = 1

# Updating the NON-unique-backed col on parent must also fail; this is the
# subset-specific check. Without correct trigger logic this would silently
# leave child(1, 10) referencing a non-existent parent(1, 10).
statement error pq: update on table "restrict_parent" violates foreign key constraint
UPDATE restrict_parent SET b = 999 WHERE a = 1

statement ok
DROP TABLE restrict_child, restrict_parent

# Same scenario with ON UPDATE CASCADE — confirms the cascade also fires on
# non-unique-backed col updates and propagates correctly.

statement ok
CREATE TABLE cascade_upd_parent (a INT PRIMARY KEY, b INT)

statement ok
CREATE TABLE cascade_upd_child (
  a INT, b INT,
  FOREIGN KEY (a, b) REFERENCES cascade_upd_parent (a, b) ON UPDATE CASCADE
)

statement ok
INSERT INTO cascade_upd_parent VALUES (1, 10), (2, 20)

statement ok
INSERT INTO cascade_upd_child VALUES (1, 10), (2, 20)

# Update the non-unique-backed col on parent; cascade should propagate to
# child.
statement count 1
UPDATE cascade_upd_parent SET b = 999 WHERE a = 1

query II rowsort
SELECT a, b FROM cascade_upd_child
----
1  999
2  20

statement ok
DROP TABLE cascade_upd_child, cascade_upd_parent

# ON DELETE SET NULL on a subset FK: deleting the parent row sets the child's
# FK columns (all of them, including non-unique-backed ones) to NULL.
statement ok
CREATE TABLE setnull_parent (a INT PRIMARY KEY, b INT, c INT)

statement ok
CREATE TABLE setnull_child (
  a INT, b INT, c INT,
  FOREIGN KEY (a, b, c) REFERENCES setnull_parent (a, b, c) ON DELETE SET NULL
)

statement ok
INSERT INTO setnull_parent VALUES (1, 10, 100), (2, 20, 200)

statement ok
INSERT INTO setnull_child VALUES (1, 10, 100), (2, 20, 200)

statement count 1
DELETE FROM setnull_parent WHERE a = 1

query III rowsort
SELECT a, b, c FROM setnull_child
----
NULL  NULL  NULL
2     20    200

statement ok
DROP TABLE setnull_child, setnull_parent

# ON DELETE SET DEFAULT on a subset FK: deleting the parent row resets the
# child's FK columns to their declared DEFAULT values. The defaults must
# themselves identify a valid parent row (here we keep a "fallback" parent
# at (0, 0, 0)).
statement ok
CREATE TABLE setdefault_parent (a INT PRIMARY KEY, b INT, c INT)

statement ok
CREATE TABLE setdefault_child (
  a INT DEFAULT 0, b INT DEFAULT 0, c INT DEFAULT 0,
  FOREIGN KEY (a, b, c) REFERENCES setdefault_parent (a, b, c) ON DELETE SET DEFAULT
)

statement ok
INSERT INTO setdefault_parent VALUES (0, 0, 0), (1, 10, 100)

statement ok
INSERT INTO setdefault_child VALUES (1, 10, 100)

statement count 1
DELETE FROM setdefault_parent WHERE a = 1

query III rowsort
SELECT a, b, c FROM setdefault_child
----
0  0  0

statement ok
DROP TABLE setdefault_child, setdefault_parent

# ON UPDATE SET NULL on a subset FK: updating any referenced column on the
# parent (including the non-unique-backed ones) sets the child's FK columns
# to NULL. Verifies the cascade fires for non-unique-backed col updates and
# uses SET NULL semantics rather than CASCADE.
statement ok
CREATE TABLE setnull_upd_parent (a INT PRIMARY KEY, b INT, c INT)

statement ok
CREATE TABLE setnull_upd_child (
  a INT, b INT, c INT,
  FOREIGN KEY (a, b, c) REFERENCES setnull_upd_parent (a, b, c) ON UPDATE SET NULL
)

statement ok
INSERT INTO setnull_upd_parent VALUES (1, 10, 100), (2, 20, 200)

statement ok
INSERT INTO setnull_upd_child VALUES (1, 10, 100), (2, 20, 200)

# Update the non-unique-backed col on parent; cascade should set the child's
# FK cols to NULL.
statement count 1
UPDATE setnull_upd_parent SET b = 999 WHERE a = 1

query III rowsort
SELECT a, b, c FROM setnull_upd_child
----
NULL  NULL  NULL
2     20    200

statement ok
DROP TABLE setnull_upd_child, setnull_upd_parent

subtest end

# MATCH SIMPLE / MATCH FULL semantics on subset FKs: the NULL-handling rules
# apply to the FULL FK column set, not just the unique-backed subset.
subtest subset_unique_match

statement ok
CREATE TABLE match_parent (a INT PRIMARY KEY, b INT, c INT)

statement ok
INSERT INTO match_parent VALUES (1, 10, 100)

# MATCH SIMPLE (default): if any FK column is NULL, the FK check is skipped
# entirely. The residual equality filter on non-unique-backed columns must
# not fire when the row is being skipped wholesale.
statement ok
CREATE TABLE match_simple_child (
  a INT, b INT, c INT,
  FOREIGN KEY (a, b, c) REFERENCES match_parent (a, b, c) MATCH SIMPLE
)

# Unique-backed col NULL → check skipped.
statement ok
INSERT INTO match_simple_child VALUES (NULL, 10, 100)

# Non-unique-backed col NULL → check also skipped (MATCH SIMPLE applies to
# the whole FK column set, including columns enforced via the residual filter
# under subset matching).
statement ok
INSERT INTO match_simple_child VALUES (1, NULL, 100)

statement ok
INSERT INTO match_simple_child VALUES (1, 10, NULL)

# All non-NULL → check enforced. Mismatch on a unique-backed col fails.
statement error pq: insert on table "match_simple_child" violates foreign key constraint
INSERT INTO match_simple_child VALUES (99, 10, 100)

# All non-NULL → check enforced. Mismatch on a non-unique-backed col fails
# (proves the residual filter still fires when no FK col is NULL).
statement error pq: insert on table "match_simple_child" violates foreign key constraint
INSERT INTO match_simple_child VALUES (1, 999, 100)

statement ok
DROP TABLE match_simple_child

# MATCH FULL: all FK columns must be all-NULL or all-non-NULL. Mixed-NULL
# rows are rejected outright with a "MATCH FULL does not allow mixing of
# null and nonnull values" error. With subset matching, this rule applies to
# the full FK column set, not just the unique-backed subset.
statement ok
CREATE TABLE match_full_child (
  a INT, b INT, c INT,
  FOREIGN KEY (a, b, c) REFERENCES match_parent (a, b, c) MATCH FULL
)

# All NULL → allowed (skipped).
statement ok
INSERT INTO match_full_child VALUES (NULL, NULL, NULL)

# All non-NULL with matching parent → succeeds.
statement ok
INSERT INTO match_full_child VALUES (1, 10, 100)

# Mixed NULL where the unique-backed col is NULL → MATCH FULL violation.
statement error MATCH FULL does not allow mixing of null and nonnull key values
INSERT INTO match_full_child VALUES (NULL, 10, 100)

# Mixed NULL where ONLY a non-unique-backed col is NULL → also a MATCH FULL
# violation. Confirms the rule applies to the full referenced column set
# under subset matching.
statement error MATCH FULL does not allow mixing of null and nonnull key values
INSERT INTO match_full_child VALUES (1, NULL, 100)

statement ok
DROP TABLE match_full_child, match_parent

subtest end
