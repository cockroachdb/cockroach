# LogicTest: default-configs 3node-tenant !local-mixed-25.4 !local-mixed-26.1 !local-mixed-26.2

# Foreign keys backed by a unique constraint covering only a subset of the
# referenced columns (CockroachDB extension). The feature is gated on cluster
# version V26_3, so the tests are excluded from the local-mixed-* configs
# where the cluster has not yet finalized to V26_3.

# Telemetry: subset-unique FK creation bumps the
# sql.schema.subset_unique_foreign_keys counter; exact-match FK creation
# does not. Placed first in the file so the counter starts at zero and
# subsequent assertions can check exact values.
subtest subset_unique_telemetry

statement ok
CREATE TABLE telemetry_parent (
  a INT PRIMARY KEY,
  b INT,
  c INT,
  UNIQUE (b),
  UNIQUE (a, b, c)
)

# Baseline: counter is zero before any FK has been created.
query I
SELECT coalesce(sum(usage_count), 0)::INT
  FROM crdb_internal.feature_usage
 WHERE feature_name = 'sql.schema.subset_unique_foreign_keys'
----
0

# Three exact-match FKs (one per available unique constraint). None
# should bump the counter.
statement ok
CREATE TABLE telemetry_child_exact_a (a INT REFERENCES telemetry_parent (a))

statement ok
CREATE TABLE telemetry_child_exact_b (b INT REFERENCES telemetry_parent (b))

statement ok
CREATE TABLE telemetry_child_exact_abc (
  a INT, b INT, c INT,
  FOREIGN KEY (a, b, c) REFERENCES telemetry_parent (a, b, c)
)

query I
SELECT coalesce(sum(usage_count), 0)::INT
  FROM crdb_internal.feature_usage
 WHERE feature_name = 'sql.schema.subset_unique_foreign_keys'
----
0

# Subset-match FK via inline FK in CREATE TABLE: bumps the counter by 1.
# The FK references (a, c). No unique constraint covers exactly (a, c),
# but PK (a) is a strict subset, so the FK is accepted via subset matching.
statement ok
CREATE TABLE telemetry_child_subset_create (
  a INT, c INT,
  FOREIGN KEY (a, c) REFERENCES telemetry_parent (a, c)
)

query I
SELECT coalesce(sum(usage_count), 0)::INT
  FROM crdb_internal.feature_usage
 WHERE feature_name = 'sql.schema.subset_unique_foreign_keys'
----
1

# Subset-match FK via ALTER TABLE ADD CONSTRAINT: bumps the counter by 1.
# Covers the ALTER path in addition to the inline-FK path above.
statement ok
CREATE TABLE telemetry_child_subset_alter (a INT, c INT)

statement ok
ALTER TABLE telemetry_child_subset_alter
  ADD CONSTRAINT subset_fk FOREIGN KEY (a, c) REFERENCES telemetry_parent (a, c)

query I
SELECT coalesce(sum(usage_count), 0)::INT
  FROM crdb_internal.feature_usage
 WHERE feature_name = 'sql.schema.subset_unique_foreign_keys'
----
2

statement ok
DROP TABLE telemetry_child_subset_alter, telemetry_child_subset_create,
  telemetry_child_exact_abc, telemetry_child_exact_b, telemetry_child_exact_a,
  telemetry_parent

subtest end

# Creation, basic DML enforcement, and edge cases for what counts as a valid
# subset backing.
subtest subset_unique_backing

statement ok
CREATE TABLE subset_parent (a INT PRIMARY KEY, b INT, c INT)

statement ok
INSERT INTO subset_parent VALUES (1, 10, 100), (2, 20, 200), (3, 30, 300)

# Default behavior: a unique constraint on a subset of the referenced columns
# is accepted. Here parent has UNIQUE(a) (the primary key) and the FK
# references (a, b, c).
statement ok
CREATE TABLE subset_child (
  a INT, b INT, c INT,
  FOREIGN KEY (a, b, c) REFERENCES subset_parent (a, b, c)
)

# Insert satisfying the FK should succeed.
statement ok
INSERT INTO subset_child VALUES (1, 10, 100), (2, 20, 200)

# Insert with non-existent parent key (a) should fail.
statement error pq: insert on table "subset_child" violates foreign key constraint
INSERT INTO subset_child VALUES (99, 0, 0)

# Insert where parent key matches but extra columns don't should also fail
# since the extra columns are enforced as implicit equality conditions.
statement error pq: insert on table "subset_child" violates foreign key constraint
INSERT INTO subset_child VALUES (1, 999, 100)

statement error pq: insert on table "subset_child" violates foreign key constraint
INSERT INTO subset_child VALUES (1, 10, 999)

# Update on the child that violates the FK should fail.
statement error pq: update on table "subset_child" violates foreign key constraint
UPDATE subset_child SET b = 999 WHERE a = 1

# Delete from parent should be blocked by RESTRICT-by-default.
statement error pq: delete on table "subset_parent" violates foreign key constraint
DELETE FROM subset_parent WHERE a = 1

statement ok
DROP TABLE subset_child, subset_parent

# Same as above, but via ALTER TABLE ADD CONSTRAINT (exercises the
# declarative schema changer path).
statement ok
CREATE TABLE subset_parent (a INT PRIMARY KEY, b INT, c INT);
CREATE TABLE subset_child (a INT, b INT, c INT)

statement ok
ALTER TABLE subset_child ADD CONSTRAINT subset_fk FOREIGN KEY (a, b, c) REFERENCES subset_parent (a, b, c)

# pg_constraint should surface the chosen backing constraint's OID (here, the
# parent's PK) in conindid, rather than 0. Confirms the introspection path
# falls back to the subset finder for subset FKs.
query B
SELECT conindid != 0
  FROM pg_catalog.pg_constraint
 WHERE conname = 'subset_fk'
----
true

statement ok
DROP TABLE subset_child, subset_parent

# Exact-match FK creation: basic coverage that an exact-match unique
# constraint backs the FK with no special handling.
statement ok
CREATE TABLE exact_parent (a INT, b INT, PRIMARY KEY (a, b))

statement ok
CREATE TABLE exact_child (
  a INT, b INT,
  FOREIGN KEY (a, b) REFERENCES exact_parent (a, b)
)

statement ok
DROP TABLE exact_child, exact_parent

# A unique constraint covering NONE of the referenced columns is still
# rejected since the relaxation requires a non-empty subset.
statement ok
CREATE TABLE no_overlap_parent (a INT PRIMARY KEY, b INT, c INT)

statement error there is no unique constraint matching given keys for referenced table no_overlap_parent
CREATE TABLE no_overlap_child (
  b INT, c INT,
  FOREIGN KEY (b, c) REFERENCES no_overlap_parent (b, c)
)

statement ok
DROP TABLE no_overlap_parent

# Partial unique indexes are still NOT eligible to back a subset FK.
statement ok
CREATE TABLE partial_subset_parent (
  a INT, b INT,
  UNIQUE INDEX (a) WHERE b > 0
)

statement error there is no unique constraint matching given keys for referenced table partial_subset_parent
CREATE TABLE partial_subset_child (
  a INT, b INT,
  FOREIGN KEY (a, b) REFERENCES partial_subset_parent (a, b)
)

statement ok
DROP TABLE partial_subset_parent

subtest end

