# LogicTest: local

# Late binding is a PL/pgSQL-only feature. LANGUAGE SQL procedures and UDFs
# always use early binding; the setting has no effect on them.
#
# The setting is ON for the entire file by default, with one exception:
# after the late_to_early_binding_transition subtest the setting is OFF for
# the remaining subtests (those that test off-behavior, including
# plpgsql_ddl_hint which also flips back to ON to test that direction).
# A final RESET in the last subtest restores the default.
statement ok
SET CLUSTER SETTING sql.procedures.plpgsql.late_binding.enabled = true

# Required by the helper views below, which select from system.descriptor.
statement ok
SET CLUSTER SETTING sql.override.allow_unsafe_internals.enabled = true

# Helper views exposing late-binding-relevant descriptor fields. Used throughout
# this file to assert presence/absence of back-references on tables, sequences,
# views, types, functions, and procedures. Field names match the descriptor
# proto so the JSON paths are still visible.
statement ok
CREATE VIEW proc_descs AS
SELECT
  d->'function'->>'name' AS name,
  (d->'function'->>'id')::INT AS id,
  COALESCE(d->'function'->'dependsOn',          '[]'::JSONB) AS depends_on,
  COALESCE(d->'function'->'dependsOnTypes',     '[]'::JSONB) AS depends_on_types,
  COALESCE(d->'function'->'dependsOnFunctions', '[]'::JSONB) AS depends_on_functions,
  COALESCE(d->'function'->'dependedOnBy',       '[]'::JSONB) AS depended_on_by
FROM (
  SELECT crdb_internal.pb_to_json('cockroach.sql.sqlbase.Descriptor', descriptor, false) d
  FROM system.descriptor
) WHERE d->'function' IS NOT NULL

statement ok
CREATE VIEW table_descs AS
SELECT
  (d->'table'->>'id')::INT AS id,
  d->'table'->>'name' AS name,
  COALESCE(d->'table'->'dependedOnBy', '[]'::JSONB) AS depended_on_by
FROM (
  SELECT crdb_internal.pb_to_json('cockroach.sql.sqlbase.Descriptor', descriptor, false) d
  FROM system.descriptor
) WHERE d->'table' IS NOT NULL

statement ok
CREATE VIEW type_descs AS
SELECT
  d->'type'->>'name' AS name,
  COALESCE(d->'type'->'referencingDescriptorIds', '[]'::JSONB) AS referencing_descriptor_ids
FROM (
  SELECT crdb_internal.pb_to_json('cockroach.sql.sqlbase.Descriptor', descriptor, false) d
  FROM system.descriptor
) WHERE d->'type' IS NOT NULL AND d->'type'->>'enumMembers' IS NOT NULL

subtest forward_reference_plpgsql

# CREATE PROCEDURE with PL/pgSQL should succeed even though t1 does not exist.
statement ok
CREATE PROCEDURE p_fwd() LANGUAGE PLpgSQL AS $$
BEGIN
  INSERT INTO t1 VALUES (1);
END
$$

# The procedure's dependsOn list should be empty (no back-references installed).
query T
SELECT depends_on FROM proc_descs WHERE name = 'p_fwd'
----
[]

# CALL should fail because t1 does not exist yet.
statement error pgcode 42P01 relation "t1" does not exist
CALL p_fwd()

# Create the table and verify CALL now works.
statement ok
CREATE TABLE t1 (c1 INT)

statement ok
CALL p_fwd()

query I
SELECT * FROM t1
----
1

# The table should NOT have a back-reference to the procedure.
let $t1_id
SELECT 't1'::regclass::oid::int

query T
SELECT depended_on_by FROM table_descs WHERE id = $t1_id
----
[]

statement ok
DROP TABLE t1

statement ok
DROP PROCEDURE p_fwd

subtest end

subtest no_dependency_protection

# With late binding, DDL on referenced objects should not be blocked.
statement ok
CREATE TABLE t_dep (a INT PRIMARY KEY, b INT, c INT)

statement ok
CREATE PROCEDURE p_dep() LANGUAGE PLpgSQL AS $$
DECLARE
  v_a INT;
  v_b INT;
BEGIN
  SELECT a, b INTO v_a, v_b FROM t_dep LIMIT 1;
END
$$

# The table should have no back-reference to the procedure.
let $t_dep_id
SELECT 't_dep'::regclass::oid::int

query T
SELECT depended_on_by FROM table_descs WHERE id = $t_dep_id
----
[]

# DROP TABLE should succeed (no dependency protection).
statement ok
DROP TABLE t_dep

# CALL should fail because the table was dropped.
statement error pgcode 42P01 relation "t_dep" does not exist
CALL p_dep()

# Re-create the table and verify CALL works again.
statement ok
CREATE TABLE t_dep (a INT PRIMARY KEY, b INT, c INT)

statement ok
CALL p_dep()

# DROP COLUMN should succeed (no dependency protection).
statement ok
ALTER TABLE t_dep DROP COLUMN b

# CALL should now fail because the body references the dropped column.
statement error pgcode 42703 column "b" does not exist
CALL p_dep()

statement ok
DROP TABLE t_dep

statement ok
DROP PROCEDURE p_dep

subtest end

