subtest syntax_errors_caught_at_create_time

# Late binding skips body analysis but still parses the body. Syntax errors,
# including those in embedded SQL statements, must be reported at CREATE
# PROCEDURE time rather than being deferred to CALL time.

# PL/pgSQL-level syntax error (missing semicolon).
statement error syntax error
CREATE PROCEDURE p_bad_plpgsql() LANGUAGE PLpgSQL AS $$
  BEGIN
    SELECT 1
  END
$$

# Embedded SQL with a syntax error (typo in keyword).
statement error syntax error
CREATE PROCEDURE p_bad_sql() LANGUAGE PLpgSQL AS $$
  BEGIN
    SELECT * FORM nonexistent_table;
  END
$$

# Invalid PL/pgSQL construct (assignment from a SELECT statement). The PL/pgSQL
# parser rejects this even though name resolution is skipped under late binding.
statement error syntax error
CREATE PROCEDURE p_bad_assign() LANGUAGE PLpgSQL AS $$
  DECLARE
    x INT;
  BEGIN
    x := SELECT 1;
  END
$$

subtest end

