subtest early_to_late_binding_transition

# Create a procedure with early binding, then CREATE OR REPLACE with late
# binding enabled. Verify old back-references are properly cleaned up.
statement ok
SET CLUSTER SETTING sql.procedures.plpgsql.late_binding.enabled = false

statement ok
CREATE TABLE t_trans (a INT PRIMARY KEY, b INT)

statement ok
CREATE PROCEDURE p_trans() LANGUAGE PLpgSQL AS $$
DECLARE
  v_a INT;
  v_b INT;
BEGIN
  SELECT a, b INTO v_a, v_b FROM t_trans LIMIT 1;
END
$$

# With early binding, the table should have a back-reference to the procedure.
let $t_trans_id
SELECT 't_trans'::regclass::oid::int

query B
SELECT jsonb_array_length(depended_on_by) > 0 FROM table_descs WHERE id = $t_trans_id
----
true

# DROP TABLE should be blocked by the back-reference.
statement error pgcode 2BP01 cannot drop table t_trans because other objects depend on it
DROP TABLE t_trans

# Now enable late binding and CREATE OR REPLACE the procedure.
statement ok
SET CLUSTER SETTING sql.procedures.plpgsql.late_binding.enabled = true

statement ok
CREATE OR REPLACE PROCEDURE p_trans() LANGUAGE PLpgSQL AS $$
DECLARE
  v_a INT;
  v_b INT;
BEGIN
  SELECT a, b INTO v_a, v_b FROM t_trans LIMIT 1;
END
$$

# The old back-reference should be cleaned up. The table should have no
# back-references now.
query T
SELECT depended_on_by FROM table_descs WHERE id = $t_trans_id
----
[]

# DROP TABLE should now succeed.
statement ok
DROP TABLE t_trans

statement ok
DROP PROCEDURE p_trans

subtest end

