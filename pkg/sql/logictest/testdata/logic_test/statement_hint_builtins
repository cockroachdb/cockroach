  'SELECT * FROM xy WHERE x = 1',
  'reorder_joins_limit',
  '4'
);

skipif config local-mixed-25.4 local-mixed-26.1
query T
SELECT fingerprint FROM system.statement_hints WHERE row_id = $sh1;
----
SELECT * FROM xy WHERE x = _

# Verify hint_type is set correctly.
skipif config local-mixed-25.4 local-mixed-26.1
query TB
SELECT hint_type, enabled FROM system.statement_hints WHERE row_id = $sh1;
----
SET VARIABLE  true

# Multiple session setting hints for the same fingerprint.
skipif config local-mixed-25.4 local-mixed-26.1
let $sh2
SELECT information_schema.crdb_set_session_variable_hint(
  'SELECT * FROM xy WHERE x = 1',
