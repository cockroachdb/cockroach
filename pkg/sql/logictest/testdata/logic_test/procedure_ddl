statement ok
DROP TABLE t_mixed;

# Nested procedures: outer CALL in implicit transaction, inner procedure has
# DDL — should work.
statement ok
CREATE PROCEDURE p_inner_ddl() LANGUAGE PLpgSQL AS $$
BEGIN
  CREATE TABLE t_nested (a INT);
END
$$;

statement ok
CREATE PROCEDURE p_outer_calls_ddl() LANGUAGE PLpgSQL AS $$
BEGIN
  CALL p_inner_ddl();
END
$$;

# Under SERIALIZABLE the nested CALL succeeds: the txn is already at the
# required isolation level so no upgrade is needed.
skipif config local-read-committed local-repeatable-read
statement ok
CALL p_outer_calls_ddl();

skipif config local-read-committed local-repeatable-read
statement ok
DROP TABLE t_nested;

