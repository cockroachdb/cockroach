----

query I
SELECT count(*) FROM t_rc_no_notice;
----
0

statement ok
DROP PROCEDURE p_rc_no_notice;

statement ok
DROP TABLE t_rc_no_notice;

statement ok
SET default_transaction_isolation = 'serializable';

subtest end


