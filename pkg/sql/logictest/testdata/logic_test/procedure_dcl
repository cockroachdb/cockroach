subtest grant_in_procedure

statement ok
CREATE PROCEDURE p_grant() LANGUAGE PLpgSQL AS $$
BEGIN
  GRANT SELECT, INSERT ON t_dcl TO r1;
END
$$;

statement ok
CALL p_grant();

query TTTTTB colnames,rowsort
