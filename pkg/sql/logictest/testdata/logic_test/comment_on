# COMMENT ON FUNCTION/PROCEDURE/ROUTINE is gated on routine ownership, not
# the EXECUTE privilege. Mirrors DROP/ALTER FUNCTION and matches PostgreSQL.
subtest comment_on_routine_privileges

skipif config local-legacy-schema-changer local-mixed-25.4 local-mixed-26.1 local-mixed-26.2
statement ok
CREATE FUNCTION fn_priv() RETURNS INT LANGUAGE SQL AS 'SELECT 1';
CREATE PROCEDURE proc_priv(x INT) LANGUAGE SQL AS 'SELECT 1';
GRANT EXECUTE ON FUNCTION fn_priv() TO testuser;
GRANT EXECUTE ON PROCEDURE proc_priv(INT) TO testuser

skipif config local-legacy-schema-changer local-mixed-25.4 local-mixed-26.1 local-mixed-26.2
statement ok
SET ROLE testuser

# EXECUTE alone is not enough to comment on a routine owned by someone else.
