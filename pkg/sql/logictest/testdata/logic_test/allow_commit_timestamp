# LogicTest: !local-mixed-25.4

# Covers the ALLOW_COMMIT_TIMESTAMP column qualification: persistence and
# SHOW CREATE TABLE roundtripping. The DDL rejection matrix lives in
# allow_commit_timestamp_disallowed_ddl.

subtest create_table_roundtrip

statement disable-cf-mutator ok
CREATE TABLE commit_ts_tab (
  id INT PRIMARY KEY,
  data STRING,
  ts TIMESTAMP ALLOW_COMMIT_TIMESTAMP
);

onlyif config schema-locked-disabled
query TT
SHOW CREATE TABLE commit_ts_tab
----
commit_ts_tab  CREATE TABLE public.commit_ts_tab (
                 id INT8 NOT NULL,
                 data STRING NULL,
                 ts TIMESTAMP NULL ALLOW_COMMIT_TIMESTAMP,
                 CONSTRAINT commit_ts_tab_pkey PRIMARY KEY (id ASC)
               );

skipif config schema-locked-disabled
query TT
SHOW CREATE TABLE commit_ts_tab
----
commit_ts_tab  CREATE TABLE public.commit_ts_tab (
                 id INT8 NOT NULL,
                 data STRING NULL,
                 ts TIMESTAMP NULL ALLOW_COMMIT_TIMESTAMP,
                 CONSTRAINT commit_ts_tab_pkey PRIMARY KEY (id ASC)
               ) WITH (schema_locked = true);

