subtest advisory_xact_lock_upgrade_blocked_by_concurrent_shared

# A session that already holds shared on a key cannot upgrade to
# exclusive while another session also holds shared on the same key.
# The earlier upgrade subtest exercised the case where the upgrader is
# the sole shared holder; this is the case where the upgrade has to
# observe a sibling shared holder.

user testuser

statement ok
SET database = defaultdb

statement ok
BEGIN

statement ok
SELECT pg_advisory_xact_lock_shared(950101)

user root

statement ok
SET database = defaultdb

statement ok
BEGIN

statement ok
SELECT pg_advisory_xact_lock_shared(950101)

# Upgrade must fail (non-blocking try) because testuser still holds
# shared on the same key.
query B
SELECT pg_try_advisory_xact_lock(950101)
----
false

statement ok
ROLLBACK

user testuser

statement ok
ROLLBACK

# Once both shared holders release, a fresh acquisition succeeds.
user root

statement ok
BEGIN

query B
SELECT pg_try_advisory_xact_lock(950101)
----
true

statement ok
COMMIT

