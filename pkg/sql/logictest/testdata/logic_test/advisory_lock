subtest advisory_xact_lock_savepoint_rollback

# Characterize how transaction advisory locks interact with savepoint
# rollback. Locks taken before the savepoint must still be held; locks
# taken inside the savepoint follow CRDB's KV concurrency layer rules
# for replicated locks (see pkg/kv/kvserver/concurrency/lock_table.go).
# The earlier lock_namespace subtest moves both connections to other
# databases; pin both back to defaultdb so locks share a keyspace.

user root

statement ok
SET database = defaultdb

statement ok
BEGIN

statement ok
SELECT pg_advisory_xact_lock(940001)

statement ok
SAVEPOINT s

statement ok
SELECT pg_advisory_xact_lock(940002)

statement ok
ROLLBACK TO SAVEPOINT s

user testuser

statement ok
SET database = defaultdb

statement ok
BEGIN

# Lock acquired before the savepoint must still be held.
query B
SELECT pg_try_advisory_xact_lock(940001)
----
false

# Lock acquired inside the savepoint: CRDB keeps the replicated lock
# even after ROLLBACK TO SAVEPOINT. This diverges from PostgreSQL,
# which decrements its per-savepoint advisory lock counter and releases
# the lock. The KV concurrency layer documents this on the replicated
# lock release path; see pkg/kv/kvserver/concurrency/lock_table.go
# (search for "savepoint rollbacks are rare enough").
query B
SELECT pg_try_advisory_xact_lock(940002)
----
false

statement ok
ROLLBACK

user root

statement ok
COMMIT

