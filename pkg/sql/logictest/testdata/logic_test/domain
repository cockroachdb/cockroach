# Table column tests: INSERT, UPDATE, DEFAULT, NOT NULL with domain types.
# =============================================================================

subtest table_insert_check

# Test CHECK constraint enforcement on INSERT.
statement ok
CREATE DOMAIN d_tbl_pos AS INT CHECK (VALUE > 0)

statement ok
CREATE TABLE t_pos (a d_tbl_pos)

statement ok
INSERT INTO t_pos VALUES (1)

statement ok
INSERT INTO t_pos VALUES (42)

statement error pgcode 23514 value for domain d_tbl_pos violates check constraint
INSERT INTO t_pos VALUES (-1)

statement error pgcode 23514 value for domain d_tbl_pos violates check constraint
INSERT INTO t_pos VALUES (0)

# NULL passes CHECK constraint (SQL standard).
statement ok
INSERT INTO t_pos VALUES (NULL)

query T rowsort
SELECT a FROM t_pos
----
1
42
NULL

subtest end

subtest table_insert_not_null

# Test domain NOT NULL enforcement on INSERT.
statement ok
CREATE DOMAIN d_tbl_nn AS INT NOT NULL

statement ok
CREATE TABLE t_nn (a d_tbl_nn)

statement ok
INSERT INTO t_nn VALUES (42)

statement error pgcode 23502 domain d_tbl_nn does not allow null values
INSERT INTO t_nn VALUES (NULL)

# DEFAULT VALUES with no default expression should also fail NOT NULL.
statement error pgcode 23502 domain d_tbl_nn does not allow null values
INSERT INTO t_nn DEFAULT VALUES

query T
SELECT a FROM t_nn
----
42

subtest end

