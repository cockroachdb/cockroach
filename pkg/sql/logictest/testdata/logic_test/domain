# Domain types are not yet supported in the declarative schema changer,
# so DROP DATABASE CASCADE will fail if it encounters domain types.
# Use the legacy schema changer as a workaround.
statement ok
SET CLUSTER SETTING sql.defaults.use_declarative_schema_changer = 'off'

statement ok
SET use_declarative_schema_changer = 'off'

# Test CREATE DOMAIN basic operations.
statement ok
CREATE DOMAIN d_int AS INT

statement ok
CREATE DOMAIN d_int8 AS INT8

statement ok
CREATE DOMAIN d_text AS TEXT

# Verify domain types appear in pg_type.
query T
SELECT typname FROM pg_type WHERE typname = 'd_int'
----
d_int

# Domain types with constraints.
statement ok
CREATE DOMAIN d_small_int AS INT DEFAULT 0 NOT NULL CHECK (VALUE > 0)

# CREATE DOMAIN with named constraints.
statement ok
CREATE DOMAIN d_bounded_int AS INT CONSTRAINT positive CHECK (VALUE > 0) CONSTRAINT small CHECK (VALUE < 100)

subtest domain_not_null

# Test NOT NULL enforcement via explicit CAST.
statement ok
CREATE DOMAIN d_nn_int AS INT NOT NULL

query error pgcode 23502 domain d_nn_int does not allow null values
SELECT CAST(NULL AS d_nn_int)

# Domain casts return domain-typed values, so use T (text) comparisons.
query T
SELECT CAST(42 AS d_nn_int)
----
42

subtest end

subtest domain_check_constraint

# Test CHECK constraint enforcement.
statement ok
CREATE DOMAIN d_pos_int AS INT CHECK (VALUE > 0)

query error pgcode 23514 value for domain d_pos_int violates check constraint
SELECT CAST(-1 AS d_pos_int)

query error pgcode 23514 value for domain d_pos_int violates check constraint
SELECT CAST(0 AS d_pos_int)

query T
SELECT CAST(1 AS d_pos_int)
----
1

query T
SELECT CAST(100 AS d_pos_int)
----
100

# NULL should pass CHECK constraint (SQL standard: CHECK treats NULL as true).
query T
SELECT CAST(NULL AS d_pos_int)
----
NULL

subtest end

subtest domain_named_check

# Test named CHECK constraints.
statement ok
CREATE DOMAIN d_bounded AS INT CONSTRAINT must_be_positive CHECK (VALUE > 0) CONSTRAINT must_be_small CHECK (VALUE < 100)

query error pgcode 23514 value for domain d_bounded violates check constraint "must_be_positive"
SELECT CAST(-5 AS d_bounded)

query error pgcode 23514 value for domain d_bounded violates check constraint "must_be_small"
SELECT CAST(200 AS d_bounded)

query T
SELECT CAST(50 AS d_bounded)
----
50

subtest end

subtest domain_not_null_and_check

