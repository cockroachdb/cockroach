statement ok
CREATE DOMAIN d_pos_nn AS INT NOT NULL CHECK (VALUE > 0)

query error pgcode 23502 domain d_pos_nn does not allow null values
SELECT CAST(NULL AS d_pos_nn)

query error pgcode 23514 value for domain d_pos_nn violates check constraint
SELECT CAST(-1 AS d_pos_nn)

