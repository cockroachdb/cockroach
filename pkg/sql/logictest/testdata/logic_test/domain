subtest domain_text_check

# Test CHECK constraint on text domain.
statement ok
CREATE DOMAIN d_nonempty_text AS TEXT NOT NULL CHECK (length(VALUE) > 0)

query error pgcode 23502 domain d_nonempty_text does not allow null values
SELECT CAST(NULL AS d_nonempty_text)

query error pgcode 23514 value for domain d_nonempty_text violates check constraint
SELECT CAST('' AS d_nonempty_text)

query T
SELECT CAST('hello' AS d_nonempty_text)
----
hello

subtest end

subtest domain_cast_syntax

# Test :: cast syntax with domain types.
statement ok
CREATE DOMAIN d_myint AS INT CHECK (VALUE >= 0)

query T
SELECT 42::d_myint
----
42

query error pgcode 23514 value for domain d_myint violates check constraint
SELECT (-1)::d_myint

subtest end

