subtest domain_update_atomicity

# Test that UPDATE violating domain CHECK on some rows rejects the entire
# statement atomically.
statement ok
CREATE DOMAIN d_atom AS INT CHECK (VALUE > 0)

statement ok
CREATE TABLE t_atom (id INT PRIMARY KEY, val d_atom)

statement ok
INSERT INTO t_atom VALUES (1, 100), (2, 5)

# This UPDATE would make val=5 for id=1 (ok) but val=-95 for id=2 (violation).
# The entire statement should be rejected.
statement error pgcode 23514 value for domain d_atom violates check constraint
UPDATE t_atom SET val = val - 100

# Verify no rows were changed.
query IT rowsort
SELECT id, val FROM t_atom
----
1  100
2  5

statement ok
DROP TABLE t_atom

statement ok
DROP DOMAIN d_atom

subtest end
