subtest domain_upsert

# Test UPSERT and ON CONFLICT with domain columns.
statement ok
CREATE DOMAIN d_upsert AS INT CHECK (VALUE > 0)

statement ok
CREATE TABLE t_upsert (id INT PRIMARY KEY, val d_upsert)

statement ok
INSERT INTO t_upsert VALUES (1, 5)

# UPSERT that violates the domain CHECK should fail.
statement error pgcode 23514 value for domain d_upsert violates check constraint
UPSERT INTO t_upsert VALUES (1, -1)

# ON CONFLICT DO UPDATE that violates the domain CHECK should fail.
statement error pgcode 23514 value for domain d_upsert violates check constraint
INSERT INTO t_upsert VALUES (1, 10) ON CONFLICT (id) DO UPDATE SET val = -1

# Valid UPSERT should succeed.
statement ok
UPSERT INTO t_upsert VALUES (1, 10)

query IT
SELECT * FROM t_upsert
----
1  10

subtest end

