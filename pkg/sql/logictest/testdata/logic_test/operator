# Regression test for issue #82478. Mixed float/int operands are supported for
# all arithmetic operators, not just division. The result type is float in
# every case, matching PostgreSQL.
subtest float_int_mixed_arithmetic

query RRTT
SELECT 1::float + 2::int, 1::int + 2::float,
       pg_typeof(1::float + 2::int), pg_typeof(1::int + 2::float)
----
3  3  double precision  double precision

query RRTT
SELECT 1::float - 2::int, 1::int - 2::float,
       pg_typeof(1::float - 2::int), pg_typeof(1::int - 2::float)
----
-1  -1  double precision  double precision

query RRTT
SELECT 1.5::float * 2::int, 2::int * 1.5::float,
       pg_typeof(1.5::float * 2::int), pg_typeof(2::int * 1.5::float)
----
3  3  double precision  double precision

query RRTT
SELECT 7.5::float // 2::int, 7::int // 2.0::float,
       pg_typeof(7.5::float // 2::int), pg_typeof(7::int // 2.0::float)
----
3  3  double precision  double precision

query RRTT
SELECT 7.5::float % 2::int, 7::int % 2.5::float,
       pg_typeof(7.5::float % 2::int), pg_typeof(7::int % 2.5::float)
----
1.5  2  double precision  double precision

query RRTT
SELECT 2.0::float ^ 3::int, 2::int ^ 3.0::float,
       pg_typeof(2.0::float ^ 3::int), pg_typeof(2::int ^ 3.0::float)
----
8  8  double precision  double precision

