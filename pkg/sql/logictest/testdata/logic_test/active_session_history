# Tests for the crdb_internal.{node,cluster}_active_session_history
# virtual tables. Locks down the column schema so future column
# additions (and any renames) trip an obvious failure here rather
# than silently breaking downstream consumers.

# Both tables must be queryable and return zero or more rows. We
# don't enable sampling, so the result is empty; the point is the
# query succeeds with the expected column types.
query TIITTTTTISSSSBTT
SELECT
  sample_time,
  node_id,
  tenant_id,
  workload_id,
  workload_type,
  app_name,
  work_event_type,
  work_event,
  goroutine_id,
  database,
  "user",
  query,
  plan_gist,
  canary_stats,
  txn_id,
  session_id
FROM crdb_internal.node_active_session_history
----

