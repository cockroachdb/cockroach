# LogicTest: local

# Test numeric formatting functions: to_char(numeric, text) and to_number(text, text)
# These tests are ported from PostgreSQL's src/test/regress/sql/numeric.sql

# Basic integer formatting
query T
SELECT to_char(0::int, '9')
----
 0

query T
SELECT to_char(0::int, '99')
----
  0

query T
SELECT to_char(1::int, '9')
----
 1

query T
SELECT to_char(-1::int, '9')
----
-1

query T
SELECT to_char(12::int, '99')
----
 12

query T
SELECT to_char(123::int, '999')
----
 123

query T
SELECT to_char(485::int, '999')
----
