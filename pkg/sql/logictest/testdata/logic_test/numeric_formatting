# ==============================
# Additional edge cases
# ==============================

# EEEE: negative decimal
query T
SELECT to_char(-0.0012345::numeric, '9.999EEEE')
----
-1.235e-03

# EEEE: large number where mantissa rounds to 10.000
query T
SELECT to_char(9999999::numeric, '9.999EEEE')
----
 10.000e+06

# EEEE: very small number
query T
SELECT to_char(0.000000001::numeric, '9.999EEEE')
----
 1.000e-09

# EEEE: zero
query T
SELECT to_char(0::numeric, '9.999EEEE')
----
 0.000e+00

# EEEE: negative zero
query T
SELECT to_char(-0.0::numeric, '9.999EEEE')
----
 0.000e+00

# FM with EEEE is an error in PostgreSQL.
statement error "EEEE" is incompatible with other formats
SELECT to_char(123.45::numeric, 'FM9.999EEEE')

# V pattern: zero
query T
SELECT to_char(0::numeric, '99V99')
----
     0

# V pattern: negative
query T
SELECT to_char(-12.34::numeric, '99V99')
----
-1234

# V pattern: trailing zeros
query T
SELECT to_char(1.2::numeric, '9V999')
----
 1200

# Float: 1/3
query T
SELECT to_char(1.0/3.0, '9.999999')
----
  .333333

# Rounding: carry across decimal point
query T
SELECT to_char(9.995::numeric, '99.99')
----
 10.00

# Rounding: small number
query T
SELECT to_char(0.0055::numeric, '9.99')
----
  .01

# Rounding: overflow
query T
SELECT to_char(99.999::numeric, '99.99')
----
 ##.##

# Sign: S suffix on negative
query T
SELECT to_char(-485::int, '999S')
----
485-

# Sign: S suffix on positive
query T
SELECT to_char(485::int, '999S')
----
485+

# Multiple comma separators
query T
SELECT to_char(1234567::int, '9,999,999')
----
 1,234,567

# Decimal with trailing zeros
query T
SELECT to_char(0.001::numeric, '0.000000')
----
 0.001000

# to_number: leading spaces
query R
SELECT to_number('  123', '9999')
----
123

# to_number: commas
query R
SELECT to_number('1,234', '9,999')
----
1234

# EEEE not supported for input.
statement error "EEEE" not supported for input
SELECT to_number('12.34e+02', '99.99EEEE')

# ==============================
# NaN and Infinity formatting
# ==============================

# NaN overflow (format too narrow for literal "NaN").
query T
SELECT to_char('NaN'::numeric, '9.999')
----
 #.###

query T
SELECT to_char('NaN'::float8, '9.999')
----
 #.###

# NaN literal display (format wide enough).
query T
SELECT to_char('NaN'::numeric, '999.9')
----
 NaN

query T
SELECT to_char('NaN'::numeric, '9999')
----
  NaN

query T
SELECT to_char('NaN'::numeric, '99')
----
 ##

# Infinity overflow.
query T
SELECT to_char('Infinity'::float8, '9.999')
----
 #.###

query T
SELECT to_char('-Infinity'::float8, '9.999')
----
-#.###

# Infinity literal display.
query T
SELECT to_char('Infinity'::float8, '9999999999')
----
   Infinity

query T
SELECT to_char('-Infinity'::float8, '9999999999')
----
  -Infinity

# EEEE NaN/Infinity overflow.
query T
SELECT to_char('NaN'::numeric, '9.999EEEE')
----
 #.#######

query T
SELECT to_char('Infinity'::float8, '9.999EEEE')
----
 #.#######

query T
SELECT to_char('-Infinity'::float8, '9.999EEEE')
