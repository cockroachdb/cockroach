# V format multiplier precision should match PostgreSQL (16+multi decimal
# places). PostgreSQL computes numeric_power(10, -multi) with 16 significant
# digits and multiplies, producing 16+multi decimal places in the result.

query T
SELECT to_number('0', '9V')::text
----
0.0000000000000000

query T
SELECT to_number('0', 'V9')::text
----
0.00000000000000000

query T
SELECT to_number('5', 'V9')::text
----
0.50000000000000000

query T
SELECT to_number('12', '9V9')::text
----
1.20000000000000000

query T
SELECT to_number('0', 'V99')::text
----
0.000000000000000000

