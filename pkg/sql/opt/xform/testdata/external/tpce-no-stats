           SELECT b_name, sum(tr_qty * tr_bid_price)::FLOAT8
             FROM broker
INNER LOOKUP JOIN trade_request ON tr_b_id = b_id
INNER LOOKUP JOIN security      ON s_symb = tr_s_symb
INNER LOOKUP JOIN company       ON co_id = s_co_id
