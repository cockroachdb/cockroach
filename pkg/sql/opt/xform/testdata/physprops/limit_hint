SELECT limhint_a.id
FROM limhint_a
INNER JOIN limhint_b ON limhint_b.x = limhint_a.id
INNER JOIN limhint_c ON limhint_c.y = limhint_b.id
LEFT JOIN LATERAL (
  SELECT limhint_d.id
