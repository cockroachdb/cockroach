# Regression test for #164666. InlineConstVar should treat placeholder
# expressions as constants, so that correlated subquery references can
# have placeholder inlined placeholder correlation is in the
# same conjunction.
subtest regression-164666

statement ok
CREATE TABLE t164666_t1 (
  k1 INT8 NOT NULL,
  k2 INT8 NOT NULL,
  a1 STRING NULL,
  fk1 INT8 NULL,
  CONSTRAINT pk_t164666_t1 PRIMARY KEY (k1 ASC),
  INDEX ix_t164666_t1_k2 (k2 ASC)
);

statement ok
CREATE TABLE t164666_t2 (
  k3 INT8 NOT NULL,
  a2 STRING NULL,
  CONSTRAINT pk_t164666_t2 PRIMARY KEY (k3 ASC)
);

statement ok
CREATE TABLE t164666_t3 (
  k4 INT8 NOT NULL,
  fk2 STRING NOT NULL DEFAULT '',
  k2 INT8 NULL,
  k1 INT8 NULL,
  b1 BOOL NULL,
  CONSTRAINT pk_t164666_t3 PRIMARY KEY (k4 ASC),
  INDEX ix_t164666_t3_k2 (k2 ASC)
);

statement ok
CREATE TABLE t164666_t4 (
  fk2 STRING NOT NULL,
  a3 STRING NULL,
  CONSTRAINT pk_t164666_t4 PRIMARY KEY (fk2 ASC)
);

statement ok
PREPARE p164666 AS SELECT t164666_t1.k1
FROM t164666_t1
INNER JOIN t164666_t2 ON t164666_t1.fk1 = t164666_t2.k3
WHERE t164666_t1.k2 = $1
AND (
  t164666_t2.a2 = 'abc'
  OR EXISTS(
    SELECT 1
    FROM t164666_t3
    INNER JOIN t164666_t4 ON t164666_t3.fk2 = t164666_t4.fk2
    WHERE t164666_t1.k1 = t164666_t3.k1
    AND t164666_t3.k2 = t164666_t1.k2
  )
);

# The plan should not contain full scans on t164666_t3. The equality on
