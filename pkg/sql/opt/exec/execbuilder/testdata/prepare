# Regression test: when the EXISTS subquery's only outer column reference
# is the placeholder-mapped column, inlining would make the subquery fully
# uncorrelated. This would prevent the parameterized scan optimization
# from firing on the outer query. Verify that the placeholder is NOT
# inlined into the subquery in this case.
statement ok
PREPARE p164666_no_uncorrelate AS SELECT t164666_t1.k1
FROM t164666_t1
WHERE t164666_t1.k1 = $1
AND EXISTS(
  SELECT 1
  FROM t164666_t3
  WHERE t164666_t3.k1 = t164666_t1.k1
);

# The plan should use a constrained scan on t1 (via the placeholder),
# not a full table scan. The subquery should remain correlated so
# that the parameterized scan optimization can fire on the outer query.
query T
