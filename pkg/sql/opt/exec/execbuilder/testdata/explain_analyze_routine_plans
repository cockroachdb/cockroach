# LogicTest: local

# Tests for surfacing routine body plans in EXPLAIN ANALYZE output.
# Issue: #170448

statement ok
CREATE TABLE t (a INT PRIMARY KEY, b INT, FAMILY (a, b))

statement ok
INSERT INTO t SELECT i, i*10 FROM generate_series(1, 10) AS g(i)

# ------------------------------------------------------------------
# 1. Single-statement volatile SQL UDF.
# ------------------------------------------------------------------
subtest single_stmt_volatile_udf

statement ok
CREATE FUNCTION lookup_volatile(x INT) RETURNS INT VOLATILE LANGUAGE SQL AS $$
  SELECT b FROM t WHERE a = x
$$

# The routine body plan should appear in a "routine" section below
# the main plan.
query T
EXPLAIN ANALYZE SELECT lookup_volatile(a) FROM t WHERE a <= 3
----
