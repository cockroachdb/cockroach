----
query cache miss
query cache add

statement ok
SET TRACING = "on", cluster;

statement ok
SELECT * FROM canary_table;

statement ok
SET TRACING = "off";

# The second execution should hit the query cache.
query T
SELECT split_part(message, ':', 1) FROM [SHOW TRACE FOR SESSION] WHERE message LIKE '%query cache%';
