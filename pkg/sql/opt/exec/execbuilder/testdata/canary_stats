# Stable execution still hits the cache — canary did not corrupt it.
statement ok
SET canary_stats_mode = force_stable;

statement ok
SET TRACING = "on", cluster;

statement ok
SELECT * FROM canary_table;

statement ok
SET TRACING = "off";

query T
