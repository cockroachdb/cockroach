# ------------------------------------------------------------------
# Eager-build path: PL/pgSQL UDF with a table read.
# PL/pgSQL routines always build their body eagerly and are never
# inlined.
# ------------------------------------------------------------------
subtest plpgsql_udf

statement ok
CREATE FUNCTION count_above_plpgsql(x INT) RETURNS INT LANGUAGE PLpgSQL AS $$
DECLARE
  result INT;
BEGIN
  SELECT count(*)::INT INTO result FROM t_ea WHERE v > x;
  RETURN result;
END
$$

