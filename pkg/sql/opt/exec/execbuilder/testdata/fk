# Foreign keys backed by a unique constraint covering only a subset of the
# referenced columns (CockroachDB extension; see require_fk_unique_constraint_on_all_columns).
# The optimizer plans the FK check as a lookup-anti-join with a residual
# equality filter on the columns not covered by the unique backing. This
# disqualifies the insert fast path because the lookup is no longer a clean
# point-get on a unique-index entry.
subtest subset_unique_fk

statement disable-cf-mutator ok
CREATE TABLE subset_p (a INT PRIMARY KEY, b INT, c INT)

# FK cols are NOT NULL so the optimizer doesn't add an IS-NOT-NULL filter,
# which would disqualify the fast path for unrelated reasons. With NOT NULL,
# the only thing keeping subset_c off the fast path is the residual equality
# filter on the non-unique-backed (b, c) columns.
statement disable-cf-mutator ok
CREATE TABLE subset_c (
  c INT PRIMARY KEY,
  a INT NOT NULL, b INT NOT NULL, sc INT NOT NULL,
  FOREIGN KEY (a, b, sc) REFERENCES subset_p (a, b, c)
)

# Subset FK insert should NOT use the insert fast path because the FK check
# requires a residual equality filter on the non-unique-backed columns.
query B
SELECT count(*) > 0 FROM [
  EXPLAIN INSERT INTO subset_c VALUES (1, 1, 10, 100)
] WHERE info LIKE '%insert fast path%'
----
false

