# Put variables on both sides of comparison operator to avoid matching constant
# patterns.
norm expect=CommuteVar
SELECT
    (1+i) = k AS r,
    (2-k) <> i AS s,
    (i+1) IS NOT DISTINCT FROM k AS t,
    (i-1) IS DISTINCT FROM k AS u,

    (i*2) + k AS v,
    (i+2) * k AS w,
    (i^2) & k AS x,
    (i^2) | k AS y,
    (i*i) # k AS z
FROM a
----
project
 в”њв”Ђв”Ђ columns: r:8 s:9 t:10!null u:11!null v:12 w:13 x:14 y:15 z:16
 в”њв”Ђв”Ђ immutable
 в”њв”Ђв”Ђ scan a
 в”‚    в”њв”Ђв”Ђ columns: k:1!null i:2
 в”‚    в”њв”Ђв”Ђ key: (1)
 в”‚    в””в”Ђв”Ђ fd: (1)-->(2)
 в””в”Ђв”Ђ projections
      в”њв”Ђв”Ђ k:1 = (i:2 + 1) [as=r:8, outer=(1,2), immutable]
      в”њв”Ђв”Ђ i:2 != (2 - k:1) [as=s:9, outer=(1,2), immutable]
      в”њв”Ђв”Ђ k:1 IS NOT DISTINCT FROM (i:2 + 1) [as=t:10, outer=(1,2), immutable]
      в”њв”Ђв”Ђ k:1 IS DISTINCT FROM (i:2 - 1) [as=u:11, outer=(1,2), immutable]
      в”њв”Ђв”Ђ k:1 + (i:2 * 2) [as=v:12, outer=(1,2), immutable]
      в”њв”Ђв”Ђ k:1 * (i:2 + 2) [as=w:13, outer=(1,2), immutable]
      в”њв”Ђв”Ђ k:1 & (i:2 ^ 2) [as=x:14, outer=(1,2), immutable]
      в”њв”Ђв”Ђ k:1 | (i:2 ^ 2) [as=y:15, outer=(1,2), immutable]
      в””в”Ђв”Ђ k:1 # (i:2 * i:2) [as=z:16, outer=(1,2), immutable]

