# Test a table with a stored and virtual computed column. Note that the
# computed columns are not included in the INSERT/UPDATE/DELETE statements.
exec
CREATE TABLE products (
  id INT,
  name STRING NOT NULL,
  unit_price DECIMAL(10,2) NOT NULL,
  quantity INT NOT NULL,
  total_value DECIMAL(10,2) GENERATED ALWAYS AS (unit_price * quantity) STORED,
  discount_price DECIMAL(10,2) GENERATED ALWAYS AS (unit_price * 0.9) VIRTUAL,
  last_updated TIMESTAMP DEFAULT now(),
  PRIMARY KEY (id, total_value)
);
----
ok

show-insert table=products
----
INSERT INTO [108 AS replication_target](id, last_updated, name, quantity, unit_price) VALUES ($1::INT8, $2::TIMESTAMP, $3::STRING, $4::INT8, $6::DECIMAL(10,2))

# NOTE: total_price and discount_price are not included since they are computed.[
show-update table=products
----
UPDATE [108 AS replication_target] SET id = $7::INT8, last_updated = $8::TIMESTAMP, name = $9::STRING, quantity = $10::INT8, unit_price = $12::DECIMAL(10,2) WHERE ((((id = $1::INT8) AND (last_updated IS NOT DISTINCT FROM $2::TIMESTAMP)) AND (name IS NOT DISTINCT FROM $3::STRING)) AND (quantity IS NOT DISTINCT FROM $4::INT8)) AND (unit_price IS NOT DISTINCT FROM $6::DECIMAL(10,2))

# NOTE: total_price and discount_price are not included since they are computed.[
show-delete table=products
----
DELETE FROM [108 AS replication_target] WHERE ((((id = $1::INT8) AND (last_updated IS NOT DISTINCT FROM $2::TIMESTAMP)) AND (name IS NOT DISTINCT FROM $3::STRING)) AND (quantity IS NOT DISTINCT FROM $4::INT8)) AND (unit_price IS NOT DISTINCT FROM $6::DECIMAL(10,2)) RETURNING *

# NOTE: total_price is not included because it is a computed column, but
