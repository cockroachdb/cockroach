load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "tsdump2duck_lib",
    srcs = ["main.go"],
    importpath = "github.com/cockroachdb/cockroach/pkg/cmd/tsdump2duck",
    visibility = ["//visibility:private"],
    deps = [
        "//pkg/roachpb",
        "//pkg/ts",
        "//pkg/ts/tsdumpmeta",
        "//pkg/ts/tspb",
    ],
)

go_binary(
    name = "tsdump2duck",
    embed = [":tsdump2duck_lib"],
    visibility = ["//visibility:public"],
)
