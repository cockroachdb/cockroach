{
  "title": "DRT Operations Runner v2",
  "description": "Observability dashboard for the roachtest operations runner. Uses Datadog events for streams and gauges for current state.",
  "widgets": [
    {
      "id": 6844866719167520,
      "definition": {
        "title": "Executions",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 7830604519284064,
            "definition": {
              "title": "Currently Running Operations",
              "type": "query_value",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "sum:roachtest_operation_active_operations{cluster:$cluster.value}",
                      "aggregator": "last"
                    }
                  ]
                }
              ],
              "precision": 0
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 3,
              "height": 1
            }
          },
          {
            "id": 8706777004172329,
            "definition": {
              "title": "Total Operations Executed",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "events",
                      "name": "a",
                      "search": {
                        "query": "cluster:$cluster.value phase:run result:(success OR failed OR panicked)"
                      },
                      "compute": {
                        "aggregation": "count"
                      }
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "a"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "precision": 0
            },
            "layout": {
              "x": 3,
              "y": 0,
              "width": 3,
              "height": 1
            }
          },
          {
            "id": 7761887439129290,
            "definition": {
              "title": "Currently Active Operations",
              "type": "query_table",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "sum:roachtest_operation_active_operations{cluster:$cluster.value} by {operation,worker}",
                      "aggregator": "last"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "query1",
                      "alias": "active",
                      "conditional_formats": [
                        {
                          "comparator": ">",
                          "value": 0,
                          "palette": "white_on_green"
                        },
                        {
                          "comparator": "<=",
                          "value": 0,
                          "palette": "white_on_gray"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            "layout": {
              "x": 6,
              "y": 0,
              "width": 6,
              "height": 3
            }
          },
          {
            "id": 3869064051060210,
            "definition": {
              "title": "Total Operations Succeeded",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "name": "a",
                      "data_source": "events",
                      "search": {
                        "query": "cluster:$cluster.value phase:run result:(success)"
                      },
                      "indexes": [
                        "*"
                      ],
                      "group_by": [],
                      "compute": {
                        "aggregation": "count"
                      },
                      "storage": "hot"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "a"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "precision": 0
            },
            "layout": {
              "x": 0,
              "y": 1,
              "width": 3,
              "height": 1
            }
          },
          {
            "id": 7119760008279525,
            "definition": {
              "title": "Operation Success Rate",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "name": "a",
                      "data_source": "events",
                      "search": {
                        "query": "cluster:$cluster.value phase:run result:(success)"
                      },
                      "indexes": [
                        "*"
                      ],
                      "group_by": [],
                      "compute": {
                        "aggregation": "count"
                      },
                      "storage": "hot"
                    },
                    {
                      "name": "query1",
                      "data_source": "events",
                      "search": {
                        "query": "cluster:$cluster.value phase:run result:(success OR failed OR panicked)"
                      },
                      "indexes": [
                        "*"
                      ],
                      "group_by": [],
                      "compute": {
                        "aggregation": "count"
                      },
                      "storage": "hot"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "a / query1 * 100",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "percent"
                        }
                      }
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "precision": 0
            },
            "layout": {
              "x": 3,
              "y": 1,
              "width": 3,
              "height": 1
            }
          },
          {
            "id": 365442178071209,
            "definition": {
              "title": "Total Operations Failed",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "name": "a",
                      "data_source": "events",
                      "search": {
                        "query": "cluster:$cluster.value phase:run result:(failed)"
                      },
                      "indexes": [
                        "*"
                      ],
                      "group_by": [],
                      "compute": {
                        "aggregation": "count"
                      },
                      "storage": "hot"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "a"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "precision": 0
            },
            "layout": {
              "x": 0,
              "y": 2,
              "width": 3,
              "height": 1
            }
          },
          {
            "id": 1349130806248567,
            "definition": {
              "title": "Total Operations Panicked",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "name": "a",
                      "data_source": "events",
                      "search": {
                        "query": "cluster:$cluster.value phase:run result:(panicked)"
                      },
                      "indexes": [
                        "*"
                      ],
                      "group_by": [],
                      "compute": {
                        "aggregation": "count"
                      },
                      "storage": "hot"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "a"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "precision": 0
            },
            "layout": {
              "x": 3,
              "y": 2,
              "width": 3,
              "height": 1
            }
          },
          {
            "id": 4918230571639842,
            "definition": {
              "title": "Executions Count Per Operation",
              "time": {},
              "type": "query_table",
              "requests": [
                {
                  "queries": [
                    {
                      "name": "a",
                      "data_source": "events",
                      "search": {
                        "query": "cluster:$cluster.value phase:run result:(success OR failed OR panicked)"
                      },
                      "indexes": [
                        "*"
                      ],
                      "group_by": [
                        {
                          "facet": "operation-name",
                          "limit": 50,
                          "sort": {
                            "aggregation": "count",
                            "order": "desc"
                          }
                        }
                      ],
                      "compute": {
                        "aggregation": "count"
                      },
                      "storage": "hot"
                    }
                  ],
                  "response_format": "scalar",
                  "formulas": [
                    {
                      "formula": "a",
                      "alias": "executions"
                    }
                  ]
                }
              ]
            },
            "layout": {
              "x": 0,
              "y": 3,
              "width": 6,
              "height": 3
            }
          },
          {
            "id": 5918230571639843,
            "definition": {
              "title": "Top 5 Longest Operations (Last Run)",
              "type": "toplist",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "top(last:roachtest_operation_last_run_duration_seconds{cluster:$cluster.value} by {operation}, 5, 'last', 'desc')",
                      "aggregator": "last"
                    }
                  ],
                  "response_format": "scalar",
                  "formulas": [
                    {
                      "formula": "query1",
                      "alias": "duration (s)"
                    }
                  ]
                }
              ]
            },
            "layout": {
              "x": 6,
              "y": 3,
              "width": 6,
              "height": 3
            }
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 12,
        "height": 7
      }
    },
