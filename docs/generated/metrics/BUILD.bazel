exports_files(
    ["metrics.yaml"],
    visibility = [
        "//pkg/testutils/metrictestutils:__pkg__",
    ],
)

genrule(
    name = "metrics",
    outs = ["metrics-generated.yaml"],
    cmd = "$(location //pkg/cmd/cockroach-short) gen metric-list --logtostderr=NONE > $@",
    tools = ["//pkg/cmd/cockroach-short"],
    visibility = [
        ":__pkg__",
        "//pkg/cmd/kv/datadoggen:__pkg__",
        "//pkg/gen:__pkg__",
        "//pkg/roachprod/agents/opentelemetry:__pkg__",
    ],
)
